@model AdmissionDetailViewModel
@{
    ViewData["Title"] = "Chi Tiet Ho So Nội trú";
    var adm = Model.Admission;
    var vitalSigns = Model.VitalSigns;
    var allergies = Model.Allergies;
    var histories = Model.MedicalHistories;
    var surgeries = Model.Surgeries;
    var prescriptions = Model.Prescriptions;
    var hasSevereAllergy = allergies.Any(a => a.Severity == AllergySeverity.Severe);
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-file-medical"></i> Ho So Nội trú: @adm.AdmissionCode</h2>
        <div class="btn-group">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
            @if (adm.Status == AdmissionStatus.Active)
            {
                <a asp-controller="MedicalOrder" asp-action="Index" asp-route-admissionId="@adm.AdmissionId" class="btn btn-primary">
                    <i class="bi bi-prescription2"></i> Lệnh điều trị
                </a>
                <a asp-controller="Surgery" asp-action="Index" asp-route-admissionId="@adm.AdmissionId" class="btn btn-danger">
                    <i class="bi bi-scissors"></i> Phau Thuat
                </a>
                <a asp-action="AddVitalSign" asp-route-admissionId="@adm.AdmissionId" class="btn btn-info">
                    <i class="bi bi-heart-pulse"></i> Sinh Hieu
                </a>
                <a asp-action="Discharge" asp-route-id="@adm.AdmissionId" class="btn btn-warning">
                    <i class="bi bi-box-arrow-right"></i> Xuat Vien
                </a>
            }
        </div>
    </div>

    @* Cảnh báo di ung va tien su benh *@
    @if (allergies.Any() || histories.Any())
    {
        <div class="alert @(hasSevereAllergy ? "alert-danger" : "alert-warning") d-flex align-items-start mb-3">
            <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
            <div class="flex-grow-1">
                <h5 class="alert-heading mb-2">
                    @(hasSevereAllergy ? "CẢNH BÁO NGHIÊM TRỌNG" : "Lưu ý trước khi ra lệnh thuốc")
                </h5>
                @if (allergies.Any())
                {
                    <div class="mb-1">
                        <strong>Dị ứng:</strong>
                        @foreach (var a in allergies)
                        {
                            var sevClass = a.Severity switch
                            {
                                AllergySeverity.Severe => "bg-danger",
                                AllergySeverity.Moderate => "bg-warning text-dark",
                                _ => "bg-info"
                            };
                            <span class="badge @sevClass me-1" title="@(a.Reaction ?? "")">
                                @a.Allergen — @a.Severity
                            </span>
                        }
                    </div>
                }
                @if (histories.Any())
                {
                    <div>
                        <strong>Tien su:</strong>
                        @foreach (var h in histories)
                        {
                            <span class="badge bg-secondary me-1">@h.Condition (@h.DiagnosedDate.ToString("yyyy"))</span>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <!-- Thông tin cơ bản -->
    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-person"></i> Thông tin Benh Nhan
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <td width="150"><strong>Họ tên:</strong></td>
                            <td>@adm.Patient?.FullName</td>
                        </tr>
                        <tr>
                            <td><strong>Ngày sinh:</strong></td>
                            <td>@adm.Patient?.Dob?.ToString("dd/MM/yyyy")</td>
                        </tr>
                        <tr>
                            <td><strong>Giới tính:</strong></td>
                            <td>@adm.Patient?.Gender</td>
                        </tr>
                        <tr>
                            <td><strong>So dien thoai:</strong></td>
                            <td>@adm.Patient?.Phone</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-clipboard2-pulse"></i> Thông tin Nhập Vien
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <td width="150"><strong>Buồng:</strong></td>
                            <td>@adm.Bed?.Ward?.Name</td>
                        </tr>
                        <tr>
                            <td><strong>Giường:</strong></td>
                            <td><span class="badge bg-info">@adm.Bed?.BedNumber</span></td>
                        </tr>
                        <tr>
                            <td><strong>Bác sĩ:</strong></td>
                            <td>@adm.AttendingDoctor?.FullName</td>
                        </tr>
                        <tr>
                            <td><strong>Nhập viện:</strong></td>
                            <td>@adm.AdmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                        <tr>
                            <td><strong>Trạng thái:</strong></td>
                            <td>
                                @if (adm.Status == AdmissionStatus.Active)
                                {
                                    <span class="badge bg-success">Đang dieu tri</span>
                                }
                                else if (adm.Status == AdmissionStatus.Discharged)
                                {
                                    <span class="badge bg-secondary">Đã xuất viện</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Ly do nhập viện & Chẩn đoán -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-clipboard-data"></i> Ly Do Nhập Vien & Chan Doan
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h6>Ly do nhập viện:</h6>
                    <p>@adm.AdmissionReason</p>
                </div>
                <div class="col-md-6">
                    <h6>Chẩn đoán ban đầu:</h6>
                    <p>@(adm.InitialDiagnosis ?? "Chưa có")</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Sinh hiệu -->
    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <i class="bi bi-heart-pulse"></i> Sinh Hieu Gan Nhat
        </div>
        <div class="card-body">
            @if (vitalSigns.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Thời gian</th>
                                <th>Nhiet do (C)</th>
                                <th>Mach (nhip/phút)</th>
                                <th>Ho hap</th>
                                <th>Hủyet ap (mmHg)</th>
                                <th>SpO2 (%)</th>
                                <th>Can nang (kg)</th>
                                <th>Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vs in vitalSigns)
                            {
                                <tr>
                                    <td>@vs.RecordedAt.ToString("dd/MM HH:mm")</td>
                                    <td>@vs.Temperature?.ToString("F1")</td>
                                    <td>@vs.HeartRate</td>
                                    <td>@vs.RespiratoryRate</td>
                                    <td>@vs.BloodPressureSystolic/@vs.BloodPressureDiastolic</td>
                                    <td>@vs.OxygenSaturation?.ToString("F1")</td>
                                    <td>@vs.Weight?.ToString("F1")</td>
                                    <td><small>@vs.Note</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center py-3">Chưa có sinh hiệu nào được ghi nhận</p>
            }
        </div>
    </div>

    @* Lệnh điều trị & đơn thuốc *@
    @if (adm.MedicalOrders.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-prescription2"></i> Lệnh điều trị (@adm.MedicalOrders.Count)</span>
                <a asp-controller="MedicalOrder" asp-action="Index" asp-route-admissionId="@adm.AdmissionId"
                    class="btn btn-sm btn-light">Xem chi tiet</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ma</th>
                            <th>Loai</th>
                            <th>Noi dung</th>
                            <th>Bác sĩ</th>
                            <th>Du kien</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in adm.MedicalOrders.OrderByDescending(x => x.ScheduledAt).Take(8))
                        {
                            <tr>
                                <td><small>@o.OrderCode</small></td>
                                <td><span class="badge bg-info">@o.OrderType</span></td>
                                <td>@o.OrderDetails</td>
                                <td>@o.OrderedByStaff?.FullName</td>
                                <td>@o.ScheduledAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                <td>
                                    @switch (o.Status)
                                    {
                                        case MedicalOrderStatus.Ordered:
                                            <span class="badge bg-warning text-dark">Cho</span>
                                            break;
                                        case MedicalOrderStatus.InProgress:
                                            <span class="badge bg-info">Đang lam</span>
                                            break;
                                        case MedicalOrderStatus.Completed:
                                            <span class="badge bg-success">Xong</span>
                                            break;
                                        case MedicalOrderStatus.Cancelled:
                                            <span class="badge bg-danger">Hủy</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* Phẩu thuật *@
    @if (surgeries.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-scissors"></i> Phau Thuat / Thu Thuat (@surgeries.Count)</span>
                <a asp-controller="Surgery" asp-action="Index" asp-route-admissionId="@adm.AdmissionId"
                    class="btn btn-sm btn-light">Xem chi tiet</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ma</th>
                            <th>Loai</th>
                            <th>PTV</th>
                            <th>Du kien</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in surgeries.Take(5))
                        {
                            <tr>
                                <td><small>@s.SurgeryCode</small></td>
                                <td>@s.SurgeryType</td>
                                <td>@s.Surgeon?.FullName</td>
                                <td>@s.ScheduledAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                <td>
                                    @{
                                        var (badge, text) = s.Status switch
                                        {
                                            SurgeryStatus.Scheduled => ("bg-warning text-dark", "Lich da xep"),
                                            SurgeryStatus.InProgress => ("bg-info", "Đang mo"),
                                            SurgeryStatus.Completed => ("bg-success", "Hoan tat"),
                                            SurgeryStatus.Cancelled => ("bg-danger", "Hủy"),
                                            SurgeryStatus.Postponed => ("bg-secondary", "Hoan"),
                                            _ => ("bg-secondary", s.Status.ToString())
                                        };
                                    }
                                    <span class="badge @badge">@text</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
