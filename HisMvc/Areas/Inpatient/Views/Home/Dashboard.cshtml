@model InpatientDashboardViewModel
@{
    ViewData["Title"] = "Dashboard - Nội trú";
}

<div data-auto-refresh="1">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0 fw-bold text-primary"><i class="bi bi-hospital"></i> Dashboard nội trú</h2>
            <small class="text-muted">
                <span class="live-indicator"></span>
                Tự động cập nhật moi 30 giay
            </small>
        </div>
        <a asp-action="Admit" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Nhập viện mới
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card">
                <div><div class="kpi-label">Đang Dieu Tri</div><div class="kpi-value">@Model.Kpi.ActiveAdmissions</div></div>
                <div class="kpi-sub"><i class="bi bi-hospital"></i> BN noi tru</div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-warning">
                <div><div class="kpi-label">Nhập Vien Hom Nay</div><div class="kpi-value">@Model.Kpi.AdmittedToday</div></div>
                <div class="kpi-sub"><i class="bi bi-box-arrow-in-right"></i> Moi</div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-success">
                <div><div class="kpi-label">Xuat Vien Hom Nay</div><div class="kpi-value">@Model.Kpi.DischargedToday</div></div>
                <div class="kpi-sub"><i class="bi bi-box-arrow-right"></i> Hoàn thành</div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-warning">
                <div><div class="kpi-label">Y Lenh Chờ TH</div><div class="kpi-value">@Model.Kpi.PendingOrders</div></div>
                <div class="kpi-sub"><i class="bi bi-clipboard-pulse"></i> Y lênh</div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-danger">
                <div><div class="kpi-label">Phau Thuat Đang TH</div><div class="kpi-value">@Model.Kpi.ActiveSurgeries</div></div>
                <div class="kpi-sub"><i class="bi bi-scissors"></i> Đang mo</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between">
                    <h5 class="mb-0"><i class="bi bi-people"></i> BN Đang Dieu Tri</h5>
                    <span class="badge bg-light text-dark">@Model.ActiveAdmissions.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.ActiveAdmissions.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr><th>Ma</th><th>Bệnh nhân</th><th>Buồng/Giường</th><th>BS</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.ActiveAdmissions)
                                {
                                    <tr>
                                        <td><strong>@a.AdmissionCode</strong></td>
                                        <td>@a.Patient?.FullName</td>
                                        <td>@a.Bed?.Ward?.Name / @a.Bed?.BedNumber</td>
                                        <td>@a.AttendingDoctor?.FullName</td>
                                        <td>
                                            <a asp-action="Detail" asp-route-id="@a.AdmissionId" class="btn btn-sm btn-primary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">Không có BN noi tru</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><span class="live-indicator"></span> Hoat Dong Gan Day</h5>
                </div>
                <div class="card-body">
                    <partial name="_ActivityFeed" model="@Model.Activities" />
                </div>
            </div>
        </div>
    </div>
</div>
