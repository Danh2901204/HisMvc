@model Admission
@{
    ViewData["Title"] = "Xuat Vien";
    var daysInHospital = (DateTime.UtcNow - Model.AdmittedAt).Days;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-box-arrow-right"></i> Xuat Vien</h2>
        <a asp-action="Detail" asp-route-id="@Model.AdmissionId" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lai
        </a>
    </div>

    <!-- Thong tin tam tat -->
    <div class="card mb-4 border-warning">
        <div class="card-header bg-warning">
            <i class="bi bi-info-circle"></i> Thong Tin Nhap Vien
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-2"><strong>Benh nhan:</strong> @Model.Patient?.FullName</p>
                    <p class="mb-2"><strong>Ma nhap vien:</strong> @Model.AdmissionCode</p>
                    <p class="mb-2"><strong>Ngay sinh:</strong> @Model.Patient?.Dob?.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="col-md-6">
                    <p class="mb-2"><strong>Buong:</strong> @Model.Bed?.Ward?.Name</p>
                    <p class="mb-2"><strong>Giuong:</strong> @Model.Bed?.BedNumber</p>
                    <p class="mb-2"><strong>Ngay nhap vien:</strong> @Model.AdmittedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-2"><strong>So ngay nam vien:</strong> <span class="badge bg-info">@daysInHospital ngay</span></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Form xuat vien -->
    <form method="post" asp-action="Discharge" asp-route-id="@Model.AdmissionId">
        @Html.AntiForgeryToken()

        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-file-text"></i> Tam Tat Benh An
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Tam tat benh an <span class="text-danger">*</span></label>
                    <textarea name="dischargeSummary" class="form-control" rows="6" required 
                              placeholder="Nhap tam tat benh an: Qua trinh dieu tri, cac xet nghiem, thuoc da dung, tinh trang hien tai...">@Model.DischargeSummary</textarea>
                    <small class="text-muted">Bao gom: Chan doan xac dinh, qua trinh dieu tri, ket qua dieu tri</small>
                </div>

                <div class="mb-3">
                    <label class="form-label">Huong dan sau xuat vien</label>
                    <textarea name="dischargeInstructions" class="form-control" rows="4"
                              placeholder="Huong dan cham soc tai nha, tai kham, dung thuoc...">@Model.DischargeInstructions</textarea>
                    <small class="text-muted">Ve du: Uong thuoc theo don, tai kham sau 1 tuan, kieng do cay nong...</small>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <i class="bi bi-exclamation-circle"></i> Luu Y Quan Trong
            </div>
            <div class="card-body">
                <div class="alert alert-warning mb-3">
                    <h6><i class="bi bi-exclamation-triangle"></i> Truoc khi xuat vien, hay kiem tra:</h6>
                    <ul class="mb-0">
                        <li>Tat ca y lenh da hoan thanh</li>
                        <li>Da cap don thuoc day du cho benh nhan</li>
                        <li>Da thanh toan vien phi (hoac ghi nhan no)</li>
                        <li>Benh nhan/nguoi nha da nhan huong dan sau xuat vien</li>
                    </ul>
                </div>

                <div class="alert alert-info mb-0">
                    <p class="mb-0">
                        <strong>Sau khi xuat vien:</strong><br />
                        - Giuong benh se chuyen sang trang thai "Cleaning" (dang dan dep)<br />
                        - Ho so se duoc chuyen sang trang thai "Discharged"<br />
                        - Co the in giay ra vien va tam tat benh an
                    </p>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Detail" asp-route-id="@Model.AdmissionId" class="btn btn-secondary btn-lg">
                <i class="bi bi-x-circle"></i> Huy
            </a>
            <button type="submit" class="btn btn-warning btn-lg" onclick="return confirm('Xac nhan xuat vien cho benh nhan @Model.Patient?.FullName?')">
                <i class="bi bi-check-circle"></i> Xac Nhan Xuat Vien
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Auto-resize textarea
        document.querySelectorAll('textarea').forEach(textarea => {
            textarea.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = this.scrollHeight + 'px';
            });
        });
    </script>
}
