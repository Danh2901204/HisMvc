@{
    ViewData["Title"] = "Nhap Vien";
    var availableBeds = (List<Bed>)ViewBag.AvailableBeds;
    var doctors = (List<Staff>)ViewBag.Doctors;
    var patient = (Patient?)ViewBag.Patient;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-plus-circle"></i> Nhap Vien Moi</h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lai
        </a>
    </div>

    @if (availableBeds.Count == 0)
    {
        <div class="alert alert-danger">
            <h5><i class="bi bi-exclamation-triangle"></i> Khong Co Giuong Trong</h5>
            <p class="mb-0">Hien tai khong co giuong trong nao trong benh vien. Vui long kiem tra lai sau.</p>
        </div>
        <a asp-controller="Ward" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-door-open"></i> Quan Li Buong Benh
        </a>
    }
    else
    {
        <form method="post" asp-action="Admit">
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-4">
                        <div class="card-header bg-primary text-white">
                            <i class="bi bi-person"></i> Thong Tin Benh Nhan
                        </div>
                        <div class="card-body">
                            @if (patient != null)
                            {
                                <input type="hidden" name="patientId" value="@patient.PatientId" />

                                <div class="mb-3">
                                    <label class="form-label"><strong>Ho ten:</strong></label>
                                    <p class="form-control-plaintext">@patient.FullName</p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label"><strong>Ngay sinh:</strong></label>
                                    <p class="form-control-plaintext">@patient.Dob?.ToString("dd/MM/yyyy")</p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label"><strong>So dien thoai:</strong></label>
                                    <p class="form-control-plaintext">@patient.Phone</p>
                                </div>
                            }
                            else
                            {
                                <div class="mb-3">
                                    <label class="form-label">Chon benh nhan <span class="text-danger">*</span></label>
                                    <input type="number" name="patientId" class="form-control" placeholder="Nhap Patient ID" required />
                                    <small class="text-muted">Hoac chon tu danh sach benh nhan da co</small>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card mb-4">
                        <div class="card-header bg-success text-white">
                            <i class="bi bi-hospital"></i> Thong Tin Nhap Vien
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Chon giuong <span class="text-danger">*</span></label>
                                <select name="bedId" class="form-select" required>
                                    <option value="">-- Chon giuong --</option>
                                    @foreach (var bed in availableBeds)
                                    {
                                        <option value="@bed.BedId">
                                            @bed.Ward?.Name - Giuong @bed.BedNumber (@bed.Ward?.Type)
                                        </option>
                                    }
                                </select>
                                <small class="text-muted">So giuong trong: <strong>@availableBeds.Count</strong></small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Bac si dieu tri <span class="text-danger">*</span></label>
                                <select name="attendingDoctorId" class="form-select" required>
                                    <option value="">-- Chon bac si --</option>
                                    @foreach (var doctor in doctors)
                                    {
                                        <option value="@doctor.StaffId">
                                            @doctor.FullName - @doctor.Department?.Name
                                        </option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-clipboard-data"></i> Ly Do Nhap Vien & Chan Doan
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Ly do nhap vien <span class="text-danger">*</span></label>
                        <textarea name="admissionReason" class="form-control" rows="3" required 
                                  placeholder="Mo ta ly do benh nhan can nhap vien..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Chon doan ban dau</label>
                        <textarea name="initialDiagnosis" class="form-control" rows="3" 
                                  placeholder="Chan doan so bo khi nhap vien (khong bat buoc)"></textarea>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary btn-lg">
                    <i class="bi bi-x-circle"></i> Huy
                </a>
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-check-circle"></i> Xac Nhan Nhap Vien
                </button>
            </div>
        </form>
    }
</div>

@section Scripts {
    <script>
        document.querySelector('form')?.addEventListener('submit', function(e) {
            if (!confirm('Xac nhan nhap vien cho benh nhan nay?')) {
                e.preventDefault();
            }
        });
    </script>
}
