@model List<Ward>
@{
    ViewData["Title"] = "Quan Li Buong Benh";
    var bedCounts = (Dictionary<int, int>)ViewBag.BedCounts;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-door-open"></i> Quan Li Buong Benh</h2>
        <div class="btn-group">
            <a asp-area="Inpatient" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Ve Danh Sach Noi Tru
            </a>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Them Buong Moi
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <h5 class="mt-3">Chua co buong benh nao</h5>
                <p class="text-muted">Nhan nut "Them Buong Moi" de bat dau</p>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var ward in Model)
            {
                var bedCount = bedCounts.ContainsKey(ward.WardId) ? bedCounts[ward.WardId] : 0;
                var bgClass = ward.Type switch
                {
                    WardType.VIP => "bg-warning",
                    WardType.ICU => "bg-danger",
                    WardType.Emergency => "bg-info",
                    _ => "bg-primary"
                };

                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-header @bgClass text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-door-closed"></i> @ward.Name
                            </h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-2"><strong>Ma:</strong> @ward.Code</p>
                            <p class="mb-2"><strong>Khoa:</strong> @ward.Department?.Name</p>
                            <p class="mb-2">
                                <strong>Loai:</strong> 
                                @if (ward.Type == WardType.VIP)
                                {
                                    <span class="badge bg-warning">VIP</span>
                                }
                                else if (ward.Type == WardType.ICU)
                                {
                                    <span class="badge bg-danger">ICU</span>
                                }
                                else if (ward.Type == WardType.Emergency)
                                {
                                    <span class="badge bg-info">Cap cuu</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Thuong</span>
                                }
                            </p>
                            <p class="mb-2">
                                <strong>So giuong:</strong> 
                                <span class="badge bg-info">@bedCount</span>
                            </p>
                            <p class="mb-2">
                                <strong>Trang thai:</strong> 
                                @if (ward.IsActive)
                                {
                                    <span class="badge bg-success">Hoat dong</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tam ngung</span>
                                }
                            </p>

                            @if (!string.IsNullOrEmpty(ward.Description))
                            {
                                <p class="mb-2 text-muted small">@ward.Description</p>
                            }
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="btn-group w-100">
                                <a asp-action="BedMap" asp-route-id="@ward.WardId" class="btn btn-primary btn-sm">
                                    <i class="bi bi-grid-3x3"></i> So do giuong
                                </a>
                                <a asp-action="Edit" asp-route-id="@ward.WardId" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-pencil"></i> Sua
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-3">
            <small class="text-muted">
                Tong so: <strong>@Model.Count</strong> buong benh | 
                Tong so giuong: <strong>@bedCounts.Values.Sum()</strong>
            </small>
        </div>
    }
</div>

<style>
    .hover-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2) !important;
    }
</style>
