@model AddBedFormViewModel
@{
    ViewData["Title"] = "Thêm Giường";
    var ward = Model.Ward;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-plus-circle"></i> Thêm Giường Moi</h2>
            <p class="text-muted mb-0">Buồng: <strong>@ward.Name</strong></p>
        </div>
        <a asp-action="BedMap" asp-route-id="@ward.WardId" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <form method="post" asp-action="AddBed">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Bed.WardId" value="@ward.WardId" />

                <div class="card">
                    <div class="card-header bg-success text-white">
                        <i class="bi bi-hospital"></i> Thông tin Giường
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Bed.BedNumber" class="form-label">So giường <span class="text-danger">*</span></label>
                            <input asp-for="Bed.BedNumber" class="form-control" placeholder="VD: A01, B02, VIP-01" required autofocus />
                            <span asp-validation-for="Bed.BedNumber" class="text-danger"></span>
                            <small class="text-muted">So giường phai duy nhat trong buong nay</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Bed.Status" class="form-label">Trạng thái ban đầu</label>
                            <select asp-for="Bed.Status" class="form-select">
                                <option value="1">Trong (Empty)</option>
                                <option value="3">Đang dan dep (Cleaning)</option>
                                <option value="4">Bao tri (Maintenance)</option>
                            </select>
                            <small class="text-muted">Trạng thái "Co bệnh nhân" sẽ tự động khi nhập viện</small>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="Bed.IsActive" class="form-check-input" type="checkbox" checked />
                                <label asp-for="Bed.IsActive" class="form-check-label">
                                    Giường dang su dung
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Bed.Note" class="form-label">Ghi chú</label>
                            <textarea asp-for="Bed.Note" class="form-control" rows="3" placeholder="Ghi chú ve giường (vi tri, dac diem...)"></textarea>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="BedMap" asp-route-id="@ward.WardId" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Hủy
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Thêm Giường
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.querySelector('input[name="Bed.BedNumber"]')?.addEventListener('blur', function() {
            this.value = this.value.toUpperCase().trim();
        });
    </script>
}
