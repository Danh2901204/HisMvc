@model WardFormViewModel
@{
    ViewData["Title"] = "Thêm Buồng Benh";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-plus-circle"></i> Thêm Buồng Benh Moi</h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()

        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-info-circle"></i> Thông tin Buồng Benh
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Ward.Code" class="form-label">Mã buong <span class="text-danger">*</span></label>
                            <input asp-for="Ward.Code" class="form-control" placeholder="VD: NOI-A, VIP-1" required />
                            <span asp-validation-for="Ward.Code" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Ward.Name" class="form-label">Tên buong <span class="text-danger">*</span></label>
                            <input asp-for="Ward.Name" class="form-control" placeholder="VD: Buồng Noi Tang Hop A" required />
                            <span asp-validation-for="Ward.Name" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Ward.DepartmentId" class="form-label">Khoa <span class="text-danger">*</span></label>
                            <select asp-for="Ward.DepartmentId" class="form-select" required>
                                <option value="">-- Chọn khoa --</option>
                                @foreach (var dept in Model.Departments)
                                {
                                    <option value="@dept.DepartmentId">@dept.Name (@dept.Code)</option>
                                }
                            </select>
                            <span asp-validation-for="Ward.DepartmentId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Ward.Type" class="form-label">Loai buong <span class="text-danger">*</span></label>
                            <select asp-for="Ward.Type" class="form-select" required>
                                <option value="1">Thuong (General)</option>
                                <option value="2">VIP</option>
                                <option value="3">ICU</option>
                                <option value="4">Cap cuu (Emergency)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Ward.TotalBeds" class="form-label">Tổng sô giường <span class="text-danger">*</span></label>
                            <input asp-for="Ward.TotalBeds" type="number" class="form-control" min="1" max="100" value="10" required />
                            <small class="text-muted">So giường toi da trong buong</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">&nbsp;</label>
                            <div class="form-check">
                                <input asp-for="Ward.IsActive" class="form-check-input" type="checkbox" checked />
                                <label asp-for="Ward.IsActive" class="form-check-label">
                                    Đang hoat dong
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Ward.Description" class="form-label">Mô tả</label>
                    <textarea asp-for="Ward.Description" class="form-control" rows="3" placeholder="Mô tả ve buong benh..."></textarea>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary btn-lg">
                <i class="bi bi-x-circle"></i> Hủy
            </a>
            <button type="submit" class="btn btn-success btn-lg">
                <i class="bi bi-save"></i> Luu Buồng Benh
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
