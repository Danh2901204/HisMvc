@model PrescriptionDetailViewModel
@{
    ViewData["Title"] = "Chi tiet đơn thuốc";
    var rx = Model.Prescription;
    var stocks = Model.Stocks;
    var canDispense = Model.CanDispense;
    var enc = rx.Encounter;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-file-earmark-medical"></i> Chi tiet đơn thuốc</h2>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    @if (rx.Status == PrescriptionStatus.Pending && !canDispense)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i>
            <strong>Chua the cấp phát:</strong> BN chua thanh toán chi phí cuoi tai Thu ngan.
            Trạng thái hien tai: <strong>@enc?.Status</strong>.
            Can chuyển sang <strong>WaitingMedicine</strong> trước khi cap thuốc.
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white"><i class="bi bi-person"></i> Thông tin bệnh nhân</div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr><td width="140"><strong>Họ tên:</strong></td><td>@enc?.Patient?.FullName</td></tr>
                        <tr><td><strong>Ngày sinh:</strong></td><td>@enc?.Patient?.Dob?.ToString("dd/MM/yyyy")</td></tr>
                        <tr><td><strong>SDT:</strong></td><td>@enc?.Patient?.Phone</td></tr>
                        <tr><td><strong>Giới tính:</strong></td><td>@enc?.Patient?.Gender</td></tr>
                        <tr>
                            <td><strong>Trạng thái KCB:</strong></td>
                            <td>
                                @switch (enc?.Status)
                                {
                                    case EncounterStatus.WaitingMedicine: <span class="badge bg-success">Chờ linh thuốc</span> break;
                                    case EncounterStatus.Completed: <span class="badge bg-secondary">Hoàn thành</span> break;
                                    case EncounterStatus.WaitingFinalPayment: <span class="badge bg-warning text-dark">Chờ thu chi phí cuoi</span> break;
                                    default: <span class="badge bg-info">@enc?.Status</span> break;
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-info text-white"><i class="bi bi-receipt"></i> Thông tin đơn thuốc</div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr><td width="140"><strong>Mã don:</strong></td><td><span class="badge bg-dark">@rx.Code</span></td></tr>
                        <tr><td><strong>Bác sĩ ke:</strong></td><td>@rx.Doctor?.FullName</td></tr>
                        <tr><td><strong>Thời gian:</strong></td><td>@rx.PrescribedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td></tr>
                        <tr>
                            <td><strong>Trạng thái:</strong></td>
                            <td>
                                @if (rx.Status == PrescriptionStatus.Pending)
                                { <span class="badge bg-warning text-dark">Chờ cấp phát</span> }
                                else if (rx.Status == PrescriptionStatus.Dispensed)
                                { <span class="badge bg-success">Đã cấp phát</span> }
                                else
                                { <span class="badge bg-secondary">Đã huy</span> }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-success text-white"><i class="bi bi-capsule"></i> Danh sách thuốc trong don</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>STT</th>
                            <th>Tên thuốc</th>
                            <th>Lieu dung</th>
                            <th>Số lượng</th>
                            <th>So ngày</th>
                            <th>Huong dan</th>
                            <th>Tồn kho</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int stt = 1; }
                        @foreach (var item in rx.Items)
                        {
                            var stock = stocks.ContainsKey(item.MedicineId) ? stocks[item.MedicineId] : 0;
                            var hasEnoughStock = stock >= item.Quantity;
                            <tr class="@(!hasEnoughStock ? "table-danger" : "")">
                                <td class="text-center">@(stt++)</td>
                                <td>
                                    <strong>@item.Medicine?.Name</strong><br />
                                    <small class="text-muted">@item.Medicine?.ActiveIngredient</small>
                                </td>
                                <td>@item.Dosage</td>
                                <td class="text-center"><span class="badge bg-primary">@item.Quantity @item.Medicine?.Unit</span></td>
                                <td class="text-center">@item.Duration ngày</td>
                                <td>@(item.Instructions ?? "—")</td>
                                <td class="text-center">
                                    @if (hasEnoughStock)
                                    { <span class="badge bg-success">@stock @item.Medicine?.Unit</span> }
                                    else
                                    { <span class="badge bg-danger">@stock @item.Medicine?.Unit (Thieu)</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (rx.Items.Any(item => !stocks.ContainsKey(item.MedicineId) || stocks[item.MedicineId] < item.Quantity))
            {
                <div class="alert alert-danger mt-3">
                    <i class="bi bi-exclamation-triangle"></i>
                    <strong>Cảnh báo:</strong> Mot so thuốc không du ton kho de cấp phát!
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(rx.Note))
    {
        <div class="card mt-3">
            <div class="card-header"><i class="bi bi-sticky"></i> Ghi chú</div>
            <div class="card-body">@rx.Note</div>
        </div>
    }

    @if (rx.Status == PrescriptionStatus.Pending && canDispense)
    {
        <div class="mt-4">
            <a asp-action="Dispense" asp-route-id="@rx.PrescriptionId" class="btn btn-success btn-lg">
                <i class="bi bi-box-seam"></i> Tien hanh cấp phát (buoc 9)
            </a>
        </div>
    }
</div>
