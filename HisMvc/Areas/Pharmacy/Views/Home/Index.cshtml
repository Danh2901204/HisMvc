@model PrescriptionListViewModel
@{
    ViewData["Title"] = "Đơn thuốc chờ cấp phát";
    var selectedDate = Model.SelectedDate;
    var selectedStatus = Model.SelectedStatus;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-capsule"></i> Đơn thuốc chờ cấp phát</h2>
            <small class="text-muted">Bước 9 — Chỉ hiện đơn sau khi BN đã thanh toán chi phí cuối (WaitingMedicine)</small>
        </div>
        <div class="btn-group">
            <a asp-action="History" class="btn btn-outline-secondary"><i class="bi bi-clock-history"></i> Lịch sử cấp phát</a>
            <a asp-controller="Medicine" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-card-list"></i> Quản lý thuốc</a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Ngay ke don</label>
                    <input type="date" name="date" class="form-control" value="@selectedDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Trạng thái</label>
                    <select name="status" class="form-select">
                        <option value="">Chờ cap (mặc định)</option>
                        <option value="Pending" selected="@(selectedStatus == PrescriptionStatus.Pending)">Chờ cấp phát</option>
                        <option value="Dispensed" selected="@(selectedStatus == PrescriptionStatus.Dispensed)">Đã cấp phát</option>
                        <option value="Cancelled" selected="@(selectedStatus == PrescriptionStatus.Cancelled)">Đã huy</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i> Loc</button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã don</th>
                            <th>Bệnh nhân</th>
                            <th>Bác sĩ</th>
                            <th>Thời gian</th>
                            <th>Số lôai</th>
                            <th>Trạng thái KCB</th>
                            <th>Trạng thái don</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Prescriptions.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    Không có đơn thuốc cho cấp phát
                                    <br /><small>Don sẽ hien khi BN da thanh toán chi phí cuoi tai Thu ngan</small>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.Prescriptions)
                            {
                                var encStatus = item.Encounter?.Status;
                                <tr>
                                    <td><strong>@item.Code</strong></td>
                                    <td>
                                        <strong>@item.Encounter?.Patient?.FullName</strong><br />
                                        <small class="text-muted">@item.Encounter?.Patient?.Phone</small>
                                    </td>
                                    <td>@item.Doctor?.FullName</td>
                                    <td>
                                        @item.PrescribedAt.ToLocalTime().ToString("dd/MM/yyyy")<br />
                                        <small class="text-muted">@item.PrescribedAt.ToLocalTime().ToString("HH:mm")</small>
                                    </td>
                                    <td><span class="badge bg-info">@item.Items.Count loai</span></td>
                                    <td>
                                        @if (encStatus == EncounterStatus.WaitingMedicine)
                                        { <span class="badge bg-success">Chờ linh thuốc</span> }
                                        else if (encStatus == EncounterStatus.Completed)
                                        { <span class="badge bg-secondary">Hoàn thành</span> }
                                        else
                                        { <span class="badge bg-warning text-dark">@encStatus</span> }
                                    </td>
                                    <td>
                                        @if (item.Status == PrescriptionStatus.Pending)
                                        { <span class="badge bg-warning text-dark">Chờ cap</span> }
                                        else if (item.Status == PrescriptionStatus.Dispensed)
                                        { <span class="badge bg-success">Đã cap</span> }
                                        else
                                        { <span class="badge bg-secondary">Đã huy</span> }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Detail" asp-route-id="@item.PrescriptionId" class="btn btn-outline-primary"><i class="bi bi-eye"></i></a>
                                            @if (item.Status == PrescriptionStatus.Pending && encStatus == EncounterStatus.WaitingMedicine)
                                            {
                                                <a asp-action="Dispense" asp-route-id="@item.PrescriptionId" class="btn btn-success"><i class="bi bi-box-seam"></i> Cap</a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3"><small class="text-muted">Tong: <strong>@Model.Prescriptions.Count</strong> don</small></div>
</div>
