@model List<MedicineBatch>
@{
    ViewData["Title"] = "T?n Kho Thu?c";
    var medicine = (Medicine)ViewBag.Medicine;
    var totalStock = (int)ViewBag.TotalStock;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-box-seam"></i> T?n Kho: @medicine.Name</h2>
            <p class="text-muted mb-0">Mã: @medicine.Code | Ho?t ch?t: @medicine.ActiveIngredient</p>
        </div>
        <div class="btn-group">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay l?i
            </a>
            <a asp-action="AddBatch" asp-route-medicineId="@medicine.MedicineId" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Nh?p Lô M?i
            </a>
        </div>
    </div>

    <!-- T?ng k?t -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-primary">@totalStock</h3>
                    <p class="mb-0 text-muted">T?ng t?n kho (@medicine.Unit)</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-success">@Model.Count(b => b.IsActive)</h3>
                    <p class="mb-0 text-muted">Lô ?ang s? d?ng</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-warning">@Model.Count(b => b.ExpiryDate <= DateTime.Today.AddMonths(3) && b.ExpiryDate > DateTime.Today)</h3>
                    <p class="mb-0 text-muted">S?p h?t h?n (&lt;3 tháng)</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-danger">@Model.Count(b => b.ExpiryDate <= DateTime.Today)</h3>
                    <p class="mb-0 text-muted">?ã h?t h?n</p>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Danh sách lô -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-list"></i> Danh Sách Lô Thu?c
        </div>
        <div class="card-body">
            @if (Model.Count == 0)
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted"></i>
                    <h5 class="mt-3">Ch?a có lô thu?c nào</h5>
                    <a asp-action="AddBatch" asp-route-medicineId="@medicine.MedicineId" class="btn btn-success mt-3">
                        <i class="bi bi-plus-circle"></i> Nh?p Lô ??u Tiên
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>S? lô</th>
                                <th>Ngày s?n xu?t</th>
                                <th>H?n dùng</th>
                                <th>??n giá</th>
                                <th>T?n kho</th>
                                <th>M?c t?i thi?u</th>
                                <th>Tr?ng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var batch in Model)
                            {
                                var daysToExpiry = (batch.ExpiryDate - DateTime.Today).Days;
                                var isExpired = batch.ExpiryDate <= DateTime.Today;
                                var isExpiringSoon = daysToExpiry <= 90 && daysToExpiry > 0;
                                var isLowStock = batch.QuantityInStock <= batch.MinStockLevel;

                                var rowClass = isExpired ? "table-danger" : isExpiringSoon ? "table-warning" : "";

                                <tr class="@rowClass">
                                    <td><strong>@batch.BatchNumber</strong></td>
                                    <td>@batch.ManufactureDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @batch.ExpiryDate.ToString("dd/MM/yyyy")
                                        @if (isExpired)
                                        {
                                            <br /><span class="badge bg-danger">?ã h?t h?n</span>
                                        }
                                        else if (isExpiringSoon)
                                        {
                                            <br /><span class="badge bg-warning">Còn @daysToExpiry ngày</span>
                                        }
                                    </td>
                                    <td>@batch.UnitPrice.ToString("N0") ?</td>
                                    <td>
                                        <strong>@batch.QuantityInStock</strong> @medicine.Unit
                                        @if (isLowStock && batch.QuantityInStock > 0)
                                        {
                                            <br /><span class="badge bg-warning">T?n th?p!</span>
                                        }
                                        else if (batch.QuantityInStock == 0)
                                        {
                                            <br /><span class="badge bg-secondary">H?t hàng</span>
                                        }
                                    </td>
                                    <td>@batch.MinStockLevel @medicine.Unit</td>
                                    <td>
                                        @if (batch.IsActive)
                                        {
                                            <span class="badge bg-success">?ang dùng</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Ng?ng</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
