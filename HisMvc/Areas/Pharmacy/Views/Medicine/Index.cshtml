@model MedicineListViewModel
@{
    ViewData["Title"] = "Quản lý thuốc";
    var search = Model.Search;
    var active = Model.Active;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-capsule-pill"></i> Quản lý thuốc</h2>
        <div class="btn-group">
            <a asp-area="Pharmacy" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Về dược
            </a>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Thêm thuốc mưới
            </a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Tìm kiếm</label>
                    <input type="text" name="search" class="form-control" value="@search" placeholder="Tên thuốc hoặc mã thuốc...">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Trạng thái</label>
                    <select name="active" class="form-select">
                        <option value="">-- Tất cả --</option>
                        <option value="true" selected="@(active == true)">Đang sử dụng</option>
                        <option value="false" selected="@(active == false)">Ngừng sử dụng</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Tim
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Ma</th>
                            <th>Tên thuốc</th>
                            <th>Hoạt chất</th>
                            <th>Đơn vị</th>
                            <th>Nhà sản xuất</th>
                            <th>Kê đơn</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Medicines.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-1"></i><br />
                                    Không tìm thấy thuốc nào
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var med in Model.Medicines)
                            {
                                <tr class="@(!med.IsActive ? "table-secondary" : "")">
                                    <td><span class="badge bg-dark">@med.Code</span></td>
                                    <td>
                                        <strong>@med.Name</strong>
                                        @if (!string.IsNullOrEmpty(med.Description))
                                        {
                                            <br /><small class="text-muted">@med.Description</small>
                                        }
                                    </td>
                                    <td>@med.ActiveIngredient</td>
                                    <td><span class="badge bg-info">@med.Unit</span></td>
                                    <td>@med.Manufacturer</td>
                                    <td>
                                        @if (med.RequiresPrescription)
                                        {
                                            <span class="badge bg-danger">Cần đơn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Không cần</span>
                                        }
                                    </td>
                                    <td>
                                        @if (med.IsActive)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Ngừng</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Stock" asp-route-id="@med.MedicineId" class="btn btn-outline-primary" title="Xem ton kho">
                                                <i class="bi bi-box-seam"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@med.MedicineId" class="btn btn-outline-secondary" title="Sua">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <small class="text-muted">Tổng sô: <strong>@Model.Medicines.Count</strong> thuốc</small>
    </div>
</div>
