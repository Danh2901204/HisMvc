@model MedicineBatch
@{
    ViewData["Title"] = "Nhập lô thuốc";
    var medicine = (Medicine)ViewBag.Medicine;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-box-seam"></i> Nhập lô thuốc mưới</h2>
            <p class="text-muted mb-0">Thuốc: <strong>@medicine.Name</strong></p>
        </div>
        <a asp-action="Stock" asp-route-id="@medicine.MedicineId" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <form method="post" asp-action="AddBatch">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="MedicineId" value="@medicine.MedicineId" />

        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <i class="bi bi-info-circle"></i> Thông tin lô thuốc
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="BatchNumber" class="form-label">Số lô <span class="text-danger">*</span></label>
                            <input asp-for="BatchNumber" class="form-control" placeholder="VD: LOT-001-2024" required autofocus />
                            <small class="text-muted">Số lô của nhà sản xuất</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="QuantityInStock" class="form-label">Số lượng <span class="text-danger">*</span></label>
                            <input asp-for="QuantityInStock" type="number" class="form-control" min="1" placeholder="1000" required />
                            <small class="text-muted">Đơn vị: @medicine.Unit</small>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ManufactureDate" class="form-label">Ngày sản xuất <span class="text-danger">*</span></label>
                            <input asp-for="ManufactureDate" type="date" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ExpiryDate" class="form-label">Hạn dùng <span class="text-danger">*</span></label>
                            <input asp-for="ExpiryDate" type="date" class="form-control" required />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="UnitPrice" class="form-label">Đơn giá <span class="text-danger">*</span></label>
                            <input asp-for="UnitPrice" type="number" class="form-control" min="0" step="100" placeholder="10000" required />
                            <small class="text-muted">VNĐ / @medicine.Unit</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="MinStockLevel" class="form-label">Mức tồn tối thiểu</label>
                            <input asp-for="MinStockLevel" type="number" class="form-control" min="0" value="50" />
                            <small class="text-muted">Cảnh báo khi tồn kho thấp hơn</small>
                        </div>
                    </div>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                    <label asp-for="IsActive" class="form-check-label">Lô thuốc đang sử dụng</label>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Stock" asp-route-id="@medicine.MedicineId" class="btn btn-secondary btn-lg">
                <i class="bi bi-x-circle"></i> Hủy
            </a>
            <button type="submit" class="btn btn-success btn-lg">
                <i class="bi bi-check-circle"></i> Xác nhận nhập kho
            </button>
        </div>
    </form>
</div>
