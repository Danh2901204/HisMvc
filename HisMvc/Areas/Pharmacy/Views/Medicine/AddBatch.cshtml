@model MedicineBatch
@{
    ViewData["Title"] = "Nh?p Lô Thu?c";
    var medicine = (Medicine)ViewBag.Medicine;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-box-seam"></i> Nh?p Lô Thu?c M?i</h2>
            <p class="text-muted mb-0">Thu?c: <strong>@medicine.Name</strong></p>
        </div>
        <a asp-action="Stock" asp-route-id="@medicine.MedicineId" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay l?i
        </a>
    </div>

    <form method="post" asp-action="AddBatch">
        @Html.AntiForgeryToken()
        <input type="hidden" name="medicineId" value="@medicine.MedicineId" />

        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <i class="bi bi-info-circle"></i> Thông Tin Lô Thu?c
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">S? lô <span class="text-danger">*</span></label>
                            <input name="batchNumber" class="form-control" placeholder="VD: LOT-001-2024" required autofocus />
                            <small class="text-muted">S? lô c?a nhŕ s?n xu?t</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">S? l??ng <span class="text-danger">*</span></label>
                            <input name="quantityInStock" type="number" class="form-control" min="1" placeholder="1000" required />
                            <small class="text-muted">??n v?: @medicine.Unit</small>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Ngŕy s?n xu?t <span class="text-danger">*</span></label>
                            <input name="manufactureDate" type="date" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">H?n důng <span class="text-danger">*</span></label>
                            <input name="expiryDate" type="date" class="form-control" required />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">??n giá <span class="text-danger">*</span></label>
                            <input name="unitPrice" type="number" class="form-control" min="0" step="100" placeholder="10000" required />
                            <small class="text-muted">VN? / @medicine.Unit</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">M?c t?n t?i thi?u</label>
                            <input name="minStockLevel" type="number" class="form-control" min="0" value="50" />
                            <small class="text-muted">C?nh báo khi t?n kho th?p h?n</small>
                        </div>
                    </div>
                </div>

                <div class="form-check mb-3">
                    <input name="isActive" class="form-check-input" type="checkbox" value="true" checked />
                    <label class="form-check-label">
                        Lô thu?c ?ang s? d?ng
                    </label>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <i class="bi bi-calculator"></i> T?ng Giá Tr?
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <p class="mb-1"><strong>S? l??ng:</strong> <span id="displayQty">0</span> @medicine.Unit</p>
                    </div>
                    <div class="col-md-4">
                        <p class="mb-1"><strong>??n giá:</strong> <span id="displayPrice">0</span> ?</p>
                    </div>
                    <div class="col-md-4">
                        <p class="mb-1"><strong>T?ng giá tr?:</strong> <span id="displayTotal" class="text-success fs-5">0 ?</span></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Stock" asp-route-id="@medicine.MedicineId" class="btn btn-secondary btn-lg">
                <i class="bi bi-x-circle"></i> H?y
            </a>
            <button type="submit" class="btn btn-success btn-lg">
                <i class="bi bi-check-circle"></i> Xác Nh?n Nh?p Kho
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Auto calculate total
        const qtyInput = document.querySelector('input[name="quantityInStock"]');
        const priceInput = document.querySelector('input[name="unitPrice"]');

        function updateTotal() {
            const qty = parseInt(qtyInput.value) || 0;
            const price = parseFloat(priceInput.value) || 0;
            const total = qty * price;

            document.getElementById('displayQty').textContent = qty.toLocaleString();
            document.getElementById('displayPrice').textContent = price.toLocaleString();
            document.getElementById('displayTotal').textContent = total.toLocaleString();
        }

        qtyInput?.addEventListener('input', updateTotal);
        priceInput?.addEventListener('input', updateTotal);

        // Validate expiry date
        const expiryInput = document.querySelector('input[name="expiryDate"]');
        const mfgInput = document.querySelector('input[name="manufactureDate"]');

        expiryInput?.addEventListener('change', function() {
            const expiry = new Date(this.value);
            const mfg = new Date(mfgInput.value);
            const today = new Date();

            if (expiry <= today) {
                alert('?? C?nh báo: H?n důng ?ă quá ho?c s?p h?t!');
            } else if (expiry <= mfg) {
                alert('? L?i: H?n důng ph?i sau ngŕy s?n xu?t!');
                this.value = '';
            }
        });
    </script>
}
