@model InsuranceConfig
@{
    ViewData["Title"] = "Thêm Cấu hình BHYT";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Thêm Cấu hình BHYT</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="InsuranceType" class="form-label">Loai The <span class="text-danger">*</span></label>
                            <input asp-for="InsuranceType" class="form-control text-uppercase" maxlength="10" placeholder="VD: QN, KC, GD, HT" required />
                            <span asp-validation-for="InsuranceType" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Mo Ta <span class="text-danger">*</span></label>
                            <input asp-for="Description" class="form-control" maxlength="200" required />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DefaultCoveragePercent" class="form-label">Ty Le Chi Tra Mac Dinh (%) <span class="text-danger">*</span></label>
                            <input asp-for="DefaultCoveragePercent" type="number" step="0.01" min="0" max="100" class="form-control" required />
                            <span asp-validation-for="DefaultCoveragePercent" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RequireRegistration" class="form-check-input" />
                            <label asp-for="RequireRegistration" class="form-check-label">Yêu cầu dang ky noi KCB ban đầu</label>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Đang hoat dong</label>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Luu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
