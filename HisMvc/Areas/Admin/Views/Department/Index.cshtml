@model DepartmentListViewModel
@{
    ViewData["Title"] = "Quản lý Khoa/Phong Ban";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-building"></i> Quản lý Khoa/Phong Ban</h2>
        <div>
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Thêm mới
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Về Dashboard
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list"></i> Danh sách Khoa/Phong Ban (@Model.Departments.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Ma</th>
                            <th>Tên Khoa/Phong Ban</th>
                            <th>Phân loại</th>
                            <th>Đặt lịch công khai</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dept in Model.Departments)
                        {
                            <tr>
                                <td><strong>@dept.DepartmentId</strong></td>
                                <td><code>@dept.Code</code></td>
                                <td>@dept.Name</td>
                                <td>@DepartmentBookingRules.GetKindLabel(dept.Kind)</td>
                                <td>
                                    @if (dept.AllowsPublicBooking)
                                    {
                                        <span class="badge bg-success">Có</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Không</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Edit", new { id = dept.DepartmentId })" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Sua
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@dept.DepartmentId" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa?')">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Xoa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
