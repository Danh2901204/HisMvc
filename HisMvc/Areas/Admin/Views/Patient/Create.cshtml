@model Patient
@{
    ViewData["Title"] = "Them Benh Nhan";
}

<div class="container-fluid mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header text-white" style="background: linear-gradient(90deg, #fa709a 0%, #fee140 100%);">
                    <h4 class="mb-0"><i class="bi bi-person-plus-fill"></i> Them Benh Nhan Moi</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        <partial name="_PatientFormFields" model="Model" />
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay Lai
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Luu Benh Nhan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
