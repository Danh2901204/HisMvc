@model List<Service>
@{
    ViewData["Title"] = "Quan Ly Dich Vu";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-heart-pulse"></i> Quan Ly Dich Vu</h2>
        <div>
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Them Moi
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Ve Dashboard
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list"></i> Danh sach Dich Vu (@Model.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Ten Dich Vu</th>
                            <th>Loai</th>
                            <th>Gia</th>
                            <th class="text-center">Thao Tac</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var service in Model)
                        {
                            <tr>
                                <td><strong>@service.ServiceId</strong></td>
                                <td>@service.Name</td>
                                <td>
                                    @if (service.Type == "LAB")
                                    {
                                        <span class="badge bg-info">
                                            <i class="bi bi-flask"></i> Xet nghiem
                                        </span>
                                    }
                                    else if (service.Type == "IMAGING")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-x-ray"></i> Chan doan hinh anh
                                        </span>
                                    }
                                    else if (service.Type == "EXAM")
                                    {
                                        <span class="badge bg-primary">
                                            <i class="bi bi-stethoscope"></i> Kham
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@service.Type</span>
                                    }
                                </td>
                                <td>
                                    <strong class="text-success">@service.Price.ToString("N0") VND</strong>
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Edit", new { id = service.ServiceId })" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Sua
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@service.ServiceId" method="post" style="display:inline;" onsubmit="return confirm('Ban co chac muon xoa dich vu nay?')">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Xoa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <div class="card">
            <div class="card-body">
                <h6>Chu thich Loai Dich Vu:</h6>
                <div class="d-flex gap-3 flex-wrap">
                    <div>
                        <span class="badge bg-info"><i class="bi bi-flask"></i> Xet nghiem</span> - Dich vu xet nghiem
                    </div>
                    <div>
                        <span class="badge bg-warning text-dark"><i class="bi bi-x-ray"></i> Chan doan hinh anh</span> - X-quang, CT, MRI, Sieu am
                    </div>
                    <div>
                        <span class="badge bg-primary"><i class="bi bi-stethoscope"></i> Kham</span> - Dich vu kham benh
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
