@model Service
@{
    ViewData["Title"] = "Them Dich Vu";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Them Dich Vu Moi</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Ten Dich Vu <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Nhap ten dich vu" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Type" class="form-label">Loai Dich Vu <span class="text-danger">*</span></label>
                            <select asp-for="Type" class="form-select" required>
                                <option value="">-- Chon loai dich vu --</option>
                                <option value="LAB">Xet nghiem</option>
                                <option value="IMAGING">Chan doan hinh anh</option>
                                <option value="EXAM">Kham</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                            <small class="text-muted">
                                <i class="bi bi-info-circle"></i> 
                                LAB: Xet nghiem mau, nuoc tieu, ... | 
                                IMAGING: X-quang, CT, MRI, ... | 
                                EXAM: Kham chuyen khoa
                            </small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label">Gia (VND) <span class="text-danger">*</span></label>
                            <input asp-for="Price" type="number" step="1000" class="form-control" placeholder="Nhap gia dich vu" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                            <small class="text-muted">Gia tinh bang VND</small>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-lightbulb"></i> 
                            <strong>Luu y:</strong> Gia dich vu nen la boi so cua 1000 de de tinh toan
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay Lai
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Luu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
