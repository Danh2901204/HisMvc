@model Service
@{
    ViewData["Title"] = "Sửa Dịch vụ";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil"></i> Sửa Dịch vụ</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="ServiceId" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Tên dịch vụ <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Type" class="form-label">Loại dịch vụ <span class="text-danger">*</span></label>
                            <select asp-for="Type" class="form-select" required>
                                <option value="">-- Chọn loại dịch vụ --</option>
                                <option value="LAB">Xet nghiem</option>
                                <option value="IMAGING">Chẩn đoán hinh anh</option>
                                <option value="EXAM">Kham</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                            <small class="text-muted">Hien tai: <strong>@Model.Type</strong></small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label">Gia (VND) <span class="text-danger">*</span></label>
                            <input asp-for="Price" type="number" step="1000" class="form-control" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                            <small class="text-muted">Gia tinh bang VND, nen la boi so cua 1000</small>
                        </div>

                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> 
                            <strong>Cảnh báo:</strong> Thay doi gia dịch vụ sẽ ảnh hưởng den cac don hang moi
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <h6><i class="bi bi-info-circle"></i> Thông tin them</h6>
                    <p class="mb-1"><strong>ID Dịch vụ:</strong> @Model.ServiceId</p>
                    <p class="mb-0"><strong>Loai:</strong> 
                        @if (Model.Type == "LAB")
                        {
                            <span class="badge bg-info">Xet nghiem</span>
                        }
                        else if (Model.Type == "IMAGING")
                        {
                            <span class="badge bg-warning text-dark">Chẩn đoán hinh anh</span>
                        }
                        else if (Model.Type == "EXAM")
                        {
                            <span class="badge bg-primary">Kham</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
