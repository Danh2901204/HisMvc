@model Staff
@{
    ViewData["Title"] = "Them Nhan Vien";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-person-plus"></i> Them Nhan Vien Moi</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Ho Ten <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="Nhap ho va ten day du" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DepartmentId" class="form-label">Khoa/Phong Ban <span class="text-danger">*</span></label>
                            <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select" required>
                                <option value="">-- Chon khoa/phong --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StaffType" class="form-label">Loai Nhan Vien <span class="text-danger">*</span></label>
                            <select asp-for="StaffType" class="form-select" required>
                                <option value="">-- Chon loai nhan vien --</option>
                                <option value="DOCTOR">Bac si</option>
                                <option value="NURSE">Dieu duong</option>
                                <option value="LAB_TECH">Ky thuat vien</option>
                                <option value="RECEPTION">Le tan</option>
                                <option value="PHARMACIST">Duoc si</option>
                                <option value="CASHIER">Thu ngan</option>
                                <option value="OTHER">Khac</option>
                            </select>
                            <span asp-validation-for="StaffType" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> 
                            <strong>Luu y:</strong> Sau khi tao nhan vien, ban co the tao tai khoan dang nhap cho ho tai trang Quan Ly Tai Khoan
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay Lai
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Luu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
