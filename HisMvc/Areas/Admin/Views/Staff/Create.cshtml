@model StaffFormViewModel
@{
    ViewData["Title"] = "Thêm Nhân viên";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-person-plus"></i> Thêm Nhân viên Moi</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Staff.FullName" class="form-label">Họ tên <span class="text-danger">*</span></label>
                            <input asp-for="Staff.FullName" class="form-control" placeholder="Nhập ho va ten đầy đủ" required />
                            <span asp-validation-for="Staff.FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Staff.DepartmentId" class="form-label">Khoa/Phong Ban <span class="text-danger">*</span></label>
                            <select asp-for="Staff.DepartmentId" asp-items="Model.Departments" class="form-select" required>
                                <option value="">-- Chọn khoa/phong --</option>
                            </select>
                            <span asp-validation-for="Staff.DepartmentId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Staff.StaffType" class="form-label">Loai Nhân viên <span class="text-danger">*</span></label>
                            <select asp-for="Staff.StaffType" class="form-select" required>
                                <option value="">-- Chọn loại nhân viên --</option>
                                <option value="DOCTOR">Bác sĩ</option>
                                <option value="NURSE">Dieu duong</option>
                                <option value="LAB_TECH">Ky thuat vien</option>
                                <option value="RECEPTION">Le tan</option>
                                <option value="PHARMACIST">Duoc si</option>
                                <option value="CASHIER">Thu ngan</option>
                                <option value="OTHER">Khác</option>
                            </select>
                            <span asp-validation-for="Staff.StaffType" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i>
                            <strong>Lưu ý:</strong> Sau khi tao nhân viên, ban co the tao tài khoản đăng nhập tai trang Quản lý Tài khoản
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Luu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
