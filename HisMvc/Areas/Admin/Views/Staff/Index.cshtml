@model List<Staff>
@{
    ViewData["Title"] = "Quan Ly Nhan Vien";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people"></i> Quan Ly Nhan Vien</h2>
        <div>
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Them Moi
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Ve Dashboard
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list"></i> Danh sach Nhan Vien (@Model.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Ho Ten</th>
                            <th>Khoa/Phong</th>
                            <th>Loai</th>
                            <th class="text-center">Thao Tac</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var staff in Model)
                        {
                            <tr>
                                <td><strong>@staff.StaffId</strong></td>
                                <td>@staff.FullName</td>
                                <td>
                                    @if (staff.Department != null)
                                    {
                                        <span class="badge bg-secondary">@staff.Department.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chua phan khoa</span>
                                    }
                                </td>
                                <td>
                                    @if (staff.StaffType == "DOCTOR")
                                    {
                                        <span class="badge bg-primary">
                                            <i class="bi bi-person-badge"></i> Bac si
                                        </span>
                                    }
                                    else if (staff.StaffType == "NURSE")
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-heart-pulse"></i> Dieu duong
                                        </span>
                                    }
                                    else if (staff.StaffType == "LAB_TECH")
                                    {
                                        <span class="badge bg-info">
                                            <i class="bi bi-flask"></i> Ky thuat vien
                                        </span>
                                    }
                                    else if (staff.StaffType == "RECEPTION")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-person-workspace"></i> Le tan
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@staff.StaffType</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Edit", new { id = staff.StaffId })" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Sua
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@staff.StaffId" method="post" style="display:inline;" onsubmit="return confirm('Ban co chac muon xoa nhan vien nay?')">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Xoa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <div class="card">
            <div class="card-body">
                <h6>Chu thich Loai Nhan Vien:</h6>
                <div class="d-flex gap-3 flex-wrap">
                    <div>
                        <span class="badge bg-primary"><i class="bi bi-person-badge"></i> Bac si</span> - Bac si chuyen khoa
                    </div>
                    <div>
                        <span class="badge bg-success"><i class="bi bi-heart-pulse"></i> Dieu duong</span> - Dieu duong vien
                    </div>
                    <div>
                        <span class="badge bg-info"><i class="bi bi-flask"></i> Ky thuat vien</span> - Ky thuat vien xet nghiem
                    </div>
                    <div>
                        <span class="badge bg-warning text-dark"><i class="bi bi-person-workspace"></i> Le tan</span> - Nhan vien le tan
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
