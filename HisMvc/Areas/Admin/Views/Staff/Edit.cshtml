@model Staff
@{
    ViewData["Title"] = "Sua Nhan Vien";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil"></i> Sua Thong Tin Nhan Vien</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="StaffId" />

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Ho Ten <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DepartmentId" class="form-label">Khoa/Phong Ban <span class="text-danger">*</span></label>
                            <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select" required>
                                <option value="">-- Chon khoa/phong --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StaffType" class="form-label">Loai Nhan Vien <span class="text-danger">*</span></label>
                            <select asp-for="StaffType" class="form-select" required>
                                <option value="">-- Chon loai nhan vien --</option>
                                <option value="DOCTOR">Bac si</option>
                                <option value="NURSE">Dieu duong</option>
                                <option value="LAB_TECH">Ky thuat vien</option>
                                <option value="RECEPTION">Le tan</option>
                                <option value="PHARMACIST">Duoc si</option>
                                <option value="CASHIER">Thu ngan</option>
                                <option value="OTHER">Khac</option>
                            </select>
                            <span asp-validation-for="StaffType" class="text-danger"></span>
                            <small class="text-muted">Hien tai: <strong>@Model.StaffType</strong></small>
                        </div>

                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> 
                            <strong>Canh bao:</strong> Thay doi thong tin nhan vien se anh huong den lich hen va tai khoan lien quan
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay Lai
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Cap Nhat
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <h6><i class="bi bi-info-circle"></i> Thong tin them</h6>
                    <p class="mb-1"><strong>ID Nhan Vien:</strong> @Model.StaffId</p>
                    <p class="mb-0"><strong>Loai:</strong> 
                        @if (Model.StaffType == "DOCTOR")
                        {
                            <span class="badge bg-primary">Bac si</span>
                        }
                        else if (Model.StaffType == "NURSE")
                        {
                            <span class="badge bg-success">Dieu duong</span>
                        }
                        else if (Model.StaffType == "LAB_TECH")
                        {
                            <span class="badge bg-info">Ky thuat vien</span>
                        }
                        else if (Model.StaffType == "RECEPTION")
                        {
                            <span class="badge bg-warning text-dark">Le tan</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
