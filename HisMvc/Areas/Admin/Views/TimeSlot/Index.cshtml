@model TimeSlotListViewModel
@{
    ViewData["Title"] = "Quản lý Khung Gio";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-clock"></i> Quản lý Khung Gio</h2>
        <div>
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Thêm mới
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Về Dashboard
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list"></i> Danh sách Khung Gio (@Model.TimeSlots.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Ma</th>
                            <th>Gio Bat Dau</th>
                            <th>Gio Ket Thuc</th>
                            <th>Thoi Luong</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var slot in Model.TimeSlots)
                        {
                            var duration = slot.End - slot.Start;
                            <tr>
                                <td><strong>@slot.TimeSlotId</strong></td>
                                <td><code>@slot.Code</code></td>
                                <td>
                                    <i class="bi bi-clock-fill text-success"></i> 
                                    @slot.Start.ToString("HH:mm")
                                </td>
                                <td>
                                    <i class="bi bi-clock-fill text-danger"></i> 
                                    @slot.End.ToString("HH:mm")
                                </td>
                                <td>
                                    <span class="badge bg-info">
                                        @duration.TotalMinutes phút
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Edit", new { id = slot.TimeSlotId })" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Sua
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@slot.TimeSlotId" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa khung giờ nay?')">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Xoa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <div class="card">
            <div class="card-body">
                <h6><i class="bi bi-info-circle"></i> Huong dan:</h6>
                <ul class="mb-0">
                    <li>Khung gio dung de phan chia thoi gian dat lich kham benh</li>
                    <li>Moi khung giờ nen co thoi luong từ 30-60 phút</li>
                    <li>Tránh khung giờ trung lap hoặc chong cheo</li>
                    <li>Nên tạo khung giờ trong giờ hành chính (8h-17h)</li>
                </ul>
            </div>
        </div>
    </div>
</div>
