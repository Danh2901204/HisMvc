@model TimeSlot
@{
    ViewData["Title"] = "Thêm Khung Gio";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Thêm Khung Gio Moi</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Code" class="form-label">Mã Khung Gio <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" required placeholder="VD: SLOT1, SLOT2, ..." />
                            <span asp-validation-for="Code" class="text-danger"></span>
                            <small class="text-muted">Mã khung giờ phai la duy nhat</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Start" class="form-label">Gio Bat Dau <span class="text-danger">*</span></label>
                            <input asp-for="Start" type="time" class="form-control" required />
                            <span asp-validation-for="Start" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="End" class="form-label">Gio Ket Thuc <span class="text-danger">*</span></label>
                            <input asp-for="End" type="time" class="form-control" required />
                            <span asp-validation-for="End" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> 
                            <strong>Lưu ý:</strong>
                            <ul class="mb-0 mt-2">
                                <li>Gio kết thúc phai sau gio bat dau</li>
                                <li>Thoi luong nen từ 30-60 phút</li>
                                <li>Tránh khung giờ trung lap</li>
                                <li>Gio làm việc: 8:00 - 17:00</li>
                            </ul>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Luu
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Preview -->
            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <h6><i class="bi bi-eye"></i> Vi du Khung Gio:</h6>
                    <div class="d-flex gap-2 flex-wrap">
                        <span class="badge bg-primary p-2">08:00 - 09:00</span>
                        <span class="badge bg-primary p-2">09:00 - 10:00</span>
                        <span class="badge bg-primary p-2">10:00 - 11:00</span>
                        <span class="badge bg-primary p-2">13:00 - 14:00</span>
                        <span class="badge bg-primary p-2">14:00 - 15:00</span>
                        <span class="badge bg-primary p-2">15:00 - 16:00</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Validation: End time must be after Start time
        document.querySelector('form').addEventListener('submit', function(e) {
            const start = document.querySelector('input[name="Start"]').value;
            const end = document.querySelector('input[name="End"]').value;
            
            if (start && end && start >= end) {
                e.preventDefault();
                alert('Gio kết thúc phai sau gio bat dau!');
            }
        });
    </script>
}
