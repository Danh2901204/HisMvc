@model UserFormViewModel
@{
    ViewData["Title"] = "Sửa Tài khoản";
    var user = Model.User!;
    var currentRole = Model.CurrentRole;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil"></i> Sửa Tài khoản</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Tên Đang Nhap</label>
                            <input value="@user.UserName" class="form-control" disabled />
                            <small class="text-muted">Không thể thay doi username</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input name="email" value="@user.Email" type="email" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Phan Quyen</label>
                            <select name="role" class="form-select">
                                <option value="">-- Không có role --</option>
                                @foreach (var role in Model.Roles)
                                {
                                    var displayName = role switch
                                    {
                                        "ADMIN" => "ADMIN - Quan tri vien",
                                        "DOCTOR" => "DOCTOR - Bác sĩ",
                                        "RECEPTION" => "RECEPTION - Le tan",
                                        "CASHIER" => "CASHIER - Thu ngan",
                                        "LAB_TECH" => "LAB_TECH - Ky thuat vien",
                                        _ => role
                                    };
                                    <option value="@role" selected="@(currentRole == role)">@displayName</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Lien Ket Nhân viên</label>
                            <select name="staffId" asp-items="Model.Staffs" class="form-select">
                                <option value="">-- Không lien ket --</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
