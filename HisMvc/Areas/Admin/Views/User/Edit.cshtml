@model AppUser
@{
    ViewData["Title"] = "Sua Tai Khoan";
    var roles = ViewBag.Roles as List<string>;
    var currentRole = ViewBag.CurrentRole as string;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil"></i> Sua Tai Khoan</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Ten Dang Nhap</label>
                            <input value="@Model.UserName" class="form-control" disabled />
                            <small class="text-muted">Khong the thay doi username</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input name="email" value="@Model.Email" type="email" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Phan Quyen</label>
                            <select name="role" class="form-select">
                                <option value="">-- Khong co role --</option>
                                @if (roles != null)
                                {
                                    foreach (var role in roles)
                                    {
                                        var displayName = role switch
                                        {
                                            "ADMIN" => "ADMIN - Quan tri vien",
                                            "DOCTOR" => "DOCTOR - Bac si",
                                            "RECEPTION" => "RECEPTION - Le tan",
                                            "CASHIER" => "CASHIER - Thu ngan",
                                            "LAB_TECH" => "LAB_TECH - Ky thuat vien",
                                            _ => role
                                        };
                                        <option value="@role" selected="@(role == currentRole)">@displayName</option>
                                    }
                                }
                            </select>
                            @if (!string.IsNullOrEmpty(currentRole))
                            {
                                <small class="text-muted">Hien tai: <strong>@currentRole</strong></small>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Lien Ket Nhan Vien (Tuy Chon)</label>
                            <select name="staffId" asp-items="ViewBag.Staffs" class="form-select">
                                <option value="">-- Khong lien ket --</option>
                            </select>
                            @if (Model.StaffId.HasValue)
                            {
                                <small class="text-muted">Dang lien ket: Staff #@Model.StaffId</small>
                            }
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> 
                            <strong>Luu y:</strong> Neu muon doi mat khau, vui long su dung chuc nang "Doi MK"
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay Lai
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Cap Nhat
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
