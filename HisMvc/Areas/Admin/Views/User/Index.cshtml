@model List<(AppUser User, string Roles)>
@{
    ViewData["Title"] = "Quan Ly Tai Khoan";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-person-gear"></i> Quan Ly Tai Khoan & Phan Quyen</h2>
        <div>
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Tao Tai Khoan
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Ve Dashboard
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list"></i> Danh sach Tai Khoan (@Model.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Nhan Vien</th>
                            <th>Phan Quyen</th>
                            <th class="text-center">Thao Tac</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.User.UserName</strong></td>
                                <td>@item.User.Email</td>
                                <td>
                                    @if (item.User.StaffId.HasValue)
                                    {
                                        <span class="badge bg-info">Staff #@item.User.StaffId</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Roles))
                                    {
                                        foreach (var role in item.Roles.Split(", "))
                                        {
                                            var badgeClass = role switch
                                            {
                                                "ADMIN" => "bg-danger",
                                                "DOCTOR" => "bg-primary",
                                                "RECEPTION" => "bg-success",
                                                "CASHIER" => "bg-warning text-dark",
                                                "LAB_TECH" => "bg-info",
                                                _ => "bg-secondary"
                                            };
                                            <span class="badge @badgeClass me-1">@role</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No Role</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Edit", new { id = item.User.Id })" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Sua
                                    </a>
                                    <a href="@Url.Action("ResetPassword", new { id = item.User.Id })" class="btn btn-sm btn-info">
                                        <i class="bi bi-key"></i> Doi MK
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.User.Id" method="post" style="display:inline;" onsubmit="return confirm('Ban co chac muon xoa tai khoan nay?')">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Xoa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <div class="card">
            <div class="card-body">
                <h6>Chu thich Phan Quyen:</h6>
                <div class="d-flex gap-3 flex-wrap">
                    <div><span class="badge bg-danger">ADMIN</span> - Quan tri vien</div>
                    <div><span class="badge bg-primary">DOCTOR</span> - Bac si</div>
                    <div><span class="badge bg-success">RECEPTION</span> - Le tan</div>
                    <div><span class="badge bg-warning text-dark">CASHIER</span> - Thu ngan</div>
                    <div><span class="badge bg-info">LAB_TECH</span> - Ky thuat vien</div>
                </div>
            </div>
        </div>
    </div>
</div>
