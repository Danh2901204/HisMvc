@model dynamic
@{
    ViewData["Title"] = "Dashboard - Admin";
}

<div class="container-fluid mt-4 pb-5 mb-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold text-primary">
                <i class="bi bi-speedometer2"></i> Dashboard Quan Tri He Thong
            </h1>
            <p class="text-muted">Tong quan hoat dong he thong</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <!-- Khoa/Phong Ban -->
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-white-50 text-uppercase mb-2">Khoa/Phong Ban</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalDepartments</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-3 p-3">
                            <i class="bi bi-building fs-2"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("Index", "Department")" class="btn btn-light btn-sm">
                            <i class="bi bi-arrow-right-circle"></i> Quan ly
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nhan Vien -->
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-white-50 text-uppercase mb-2">Nhan Vien</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalStaff</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-3 p-3">
                            <i class="bi bi-people-fill fs-2"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("Index", "Staff")" class="btn btn-light btn-sm">
                            <i class="bi bi-arrow-right-circle"></i> Quan ly
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dich Vu -->
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-white-50 text-uppercase mb-2">Dich Vu</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalServices</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-3 p-3">
                            <i class="bi bi-heart-pulse-fill fs-2"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("Index", "Service")" class="btn btn-light btn-sm">
                            <i class="bi bi-arrow-right-circle"></i> Quan ly
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Benh Nhan -->
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                <div class="card-body text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-white-50 text-uppercase mb-2">Benh Nhan</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalPatients</h2>
                        </div>
                        <div class="bg-white bg-opacity-25 rounded-3 p-3">
                            <i class="bi bi-person-hearts fs-2"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-white text-dark">
                            <i class="bi bi-graph-up-arrow"></i> Tong so
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lich Hen Hom Nay -->
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);">
                <div class="card-body" style="color: #333;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted text-uppercase mb-2">Lich Hen Hom Nay</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalAppointmentsToday</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-calendar-check-fill fs-2 text-primary"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-primary">
                            <i class="bi bi-clock"></i> Hom nay
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Ca Kham Hom Nay -->
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);">
                <div class="card-body" style="color: #333;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted text-uppercase mb-2">Ca Kham Hom Nay</h6>
                            <h2 class="mb-0 fw-bold">@Model.TotalEncountersToday</h2>
                        </div>
                        <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-clipboard2-pulse-fill fs-2 text-danger"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-danger">
                            <i class="bi bi-activity"></i> Hoat dong
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-4 mb-5">
        <!-- Quan Ly He Thong -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-gradient text-white" style="background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="mb-0">
                        <i class="bi bi-gear-fill"></i> Quan Ly He Thong
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <a href="@Url.Action("Index", "Department")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span>
                                <i class="bi bi-building text-primary"></i> Khoa/Phong Ban
                            </span>
                            <span class="badge bg-primary rounded-pill">@Model.TotalDepartments</span>
                        </a>
                        <a href="@Url.Action("Index", "Staff")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span>
                                <i class="bi bi-people text-success"></i> Nhan Vien
                            </span>
                            <span class="badge bg-success rounded-pill">@Model.TotalStaff</span>
                        </a>
                        <a href="@Url.Action("Index", "Service")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span>
                                <i class="bi bi-heart-pulse text-info"></i> Dich Vu
                            </span>
                            <span class="badge bg-info rounded-pill">@Model.TotalServices</span>
                        </a>
                        <a href="@Url.Action("Index", "TimeSlot")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span>
                                <i class="bi bi-clock text-warning"></i> Khung Gio
                            </span>
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quan Ly Tai Khoan -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-gradient text-white" style="background: linear-gradient(90deg, #f093fb 0%, #f5576c 100%);">
                    <h5 class="mb-0">
                        <i class="bi bi-person-gear"></i> Quan Ly Tai Khoan
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <a href="@Url.Action("Index", "User")" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span>
                                <i class="bi bi-person-badge text-danger"></i> Tai Khoan & Phan Quyen
                            </span>
                            <i class="bi bi-chevron-right"></i>
                        </a>
                        <div class="list-group-item">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-shield-check text-success fs-4 me-3"></i>
                                <div>
                                    <h6 class="mb-1">Bao mat he thong</h6>
                                    <small class="text-muted">Quan ly quyen han va bao mat</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
    body {
        padding-bottom: 100px;
    }
    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
    }
    .list-group-item {
        transition: all 0.2s;
    }
    .list-group-item:hover {
        background-color: #f8f9fa;
        padding-left: 1.5rem;
    }
</style>
}
