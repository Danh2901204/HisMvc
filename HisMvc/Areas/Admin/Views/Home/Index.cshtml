@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard - Admin";
}

<div data-auto-refresh="1">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0 fw-bold text-primary">
                <i class="bi bi-speedometer2"></i> Dashboard
            </h2>
            <small class="text-muted">
                <span class="live-indicator"></span>
                Cập nhật tự động moi 30 giay · @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
            </small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* KPI strip *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-info">
                <div>
                    <div class="kpi-label">Lịch hẹn hôm nay</div>
                    <div class="kpi-value">@Model.Kpi.TotalAppointmentsToday</div>
                </div>
                <div class="kpi-sub"><i class="bi bi-calendar-check"></i> Le tan</div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card">
                <div>
                    <div class="kpi-label">Ca Kham Hom Nay</div>
                    <div class="kpi-value">@Model.Kpi.TotalEncountersToday</div>
                </div>
                <div class="kpi-sub"><i class="bi bi-stethoscope"></i> Bác sĩ</div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-warning">
                <div>
                    <div class="kpi-label">Chỉ định chờ xử lý</div>
                    <div class="kpi-value">@Model.Kpi.PendingOrders</div>
                </div>
                <div class="kpi-sub"><i class="bi bi-flask"></i> Lab / Imaging</div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-warning">
                <div>
                    <div class="kpi-label">Don Thuốc Chờ Cap</div>
                    <div class="kpi-value">@Model.Kpi.PendingPrescriptions</div>
                </div>
                <div class="kpi-sub"><i class="bi bi-capsule"></i> Duoc</div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-danger">
                <div>
                    <div class="kpi-label">HD Chua Thu</div>
                    <div class="kpi-value">@Model.Kpi.UnpaidInvoices</div>
                </div>
                <div class="kpi-sub"><i class="bi bi-cash-coin"></i> Thu ngan</div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-success">
                <div>
                    <div class="kpi-label">Doanh Thu Hom Nay</div>
                    <div class="kpi-value" style="font-size: 1.4rem;">@(((decimal)Model.Kpi.RevenueToday).ToString("N0"))</div>
                </div>
                <div class="kpi-sub">VND đã thu</div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-info">
                <div>
                    <div class="kpi-label">BN Nội trú</div>
                    <div class="kpi-value">@Model.Kpi.ActiveAdmissions</div>
                </div>
                <div class="kpi-sub"><i class="bi bi-hospital"></i> Đang dieu tri</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card">
                <div>
                    <div class="kpi-label">Giám định BHYT</div>
                    <div class="kpi-value">@Model.Kpi.PendingClaims</div>
                </div>
                <div class="kpi-sub"><i class="bi bi-shield-check"></i> Chờ xu ly</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card">
                <div>
                    <div class="kpi-label">Tổng Benh Nhan</div>
                    <div class="kpi-value">@Model.Kpi.TotalPatients</div>
                </div>
                <div class="kpi-sub"><i class="bi bi-person-hearts"></i> Trong he thong</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card">
                <div>
                    <div class="kpi-label">Nhân viên</div>
                    <div class="kpi-value">@Model.Kpi.TotalStaff</div>
                </div>
                <div class="kpi-sub"><i class="bi bi-people"></i> @Model.Kpi.TotalDepartments khoa / phong</div>
            </div>
        </div>
    </div>

    @* Live activity feed *@
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <span class="live-indicator"></span>
                Hoat Dong Gan Day
            </h5>
            <small class="text-muted">Tự động cập nhật</small>
        </div>
        <div class="card-body">
            <partial name="_ActivityFeed" model="@Model.Activities" />
        </div>
    </div>
</div>
