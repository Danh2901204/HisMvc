@model CashierDashboardViewModel
@{
    ViewData["Title"] = "Dashboard - Thu ngân";
}

<div data-auto-refresh="1">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0 fw-bold text-primary"><i class="bi bi-cash-coin"></i> Dashboard thu ngân</h2>
            <small class="text-muted">
                <span class="live-indicator"></span>
                Tự động cập nhật moi 30 giay
            </small>
        </div>
        <a asp-action="Pending" class="btn btn-warning">
            <i class="bi bi-clock"></i> Chờ thu chi phí cuoi (@Model.Kpi.UnpaidFinal)
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-danger">
                <div><div class="kpi-label">Phí khám chua thu</div><div class="kpi-value">@Model.Kpi.UnpaidExamFee</div></div>
                <div class="kpi-sub"><i class="bi bi-1-circle"></i> Bước 2 luong</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-warning">
                <div><div class="kpi-label">Chi phí cuoi chua thu</div><div class="kpi-value">@Model.Kpi.UnpaidFinal</div></div>
                <div class="kpi-sub"><i class="bi bi-8-circle"></i> Bước 8 luong</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-success">
                <div><div class="kpi-label">Đã Thu Hom Nay</div><div class="kpi-value">@Model.Kpi.PaidToday</div></div>
                <div class="kpi-sub"><i class="bi bi-check-circle"></i> Hoa don</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-success">
                <div>
                    <div class="kpi-label">Doanh Thu BN</div>
                    <div class="kpi-value" style="font-size:1.4rem;">@Model.Kpi.RevenueToday.ToString("N0")</div>
                </div>
                <div class="kpi-sub">VND tu BN</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-info">
                <div>
                    <div class="kpi-label">BHYT Chi Tra</div>
                    <div class="kpi-value" style="font-size:1.4rem;">@Model.Kpi.InsuranceToday.ToString("N0")</div>
                </div>
                <div class="kpi-sub">VND tu BHYT</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-danger text-white d-flex justify-content-between">
                    <h5 class="mb-0"><i class="bi bi-hourglass-split"></i> Hoa Don Chua Thu</h5>
                    <span class="badge bg-light text-dark">@Model.UnpaidInvoices.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.UnpaidInvoices.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr><th>Mã HD</th><th>Loai</th><th>Bệnh nhân</th><th>Tien thu</th><th>Tạo luc</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var i in Model.UnpaidInvoices)
                                {
                                    var typeLabel = InvoiceDisplay.TypeLabel(i.InvoiceType);
                                    <tr>
                                        <td><strong>@i.InvoiceCode</strong></td>
                                        <td><span class="badge @(i.InvoiceType == InvoiceType.ExamFee ? "bg-primary" : "bg-warning text-dark")">@typeLabel</span></td>
                                        <td>@i.Encounter?.Patient?.FullName</td>
                                        <td><strong>@i.PatientAmount.ToString("N0")</strong></td>
                                        <td><small>@i.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</small></td>
                                        <td>
                                            <a asp-action="Detail" asp-route-id="@i.InvoiceId" class="btn btn-sm btn-success">
                                                <i class="bi bi-cash"></i> Thu
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4 mb-0">
                            <i class="bi bi-check-circle fs-1 d-block mb-2 text-success"></i>
                            Không có hóa đơn chua thu
                        </p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><span class="live-indicator"></span> Hoat Dong Gan Day</h5>
                </div>
                <div class="card-body">
                    <partial name="_ActivityFeed" model="@Model.Activities" />
                </div>
            </div>
        </div>
    </div>
</div>
