@model Invoice
@{
    ViewData["Title"] = "Chi tiet hoa don";
    var orders = (List<Order>)ViewBag.Orders;
    var examFee = (decimal)ViewBag.ExamFee;
    var isPaid = Model.Status == InvoiceStatus.Paid;
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header @(isPaid ? "bg-success" : "bg-warning text-dark") text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-receipt"></i> Hoa don: @Model.InvoiceCode
                        @if (isPaid)
                        {
                            <span class="badge bg-light text-success float-end">
                                <i class="bi bi-check-circle"></i> Da thanh toan
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger float-end">
                                <i class="bi bi-hourglass-split"></i> Chua thanh toan
                            </span>
                        }
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="mb-2">
                                <strong><i class="bi bi-person-fill text-primary"></i> Benh nhan:</strong><br />
                                <span class="ms-4 fs-5">@Model.Encounter?.Patient?.FullName</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-telephone-fill text-success"></i> Dien thoai:</strong><br />
                                <span class="ms-4">@Model.Encounter?.Patient?.Phone</span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2">
                                <strong><i class="bi bi-person-badge-fill text-info"></i> Bac si:</strong><br />
                                <span class="ms-4">@Model.Encounter?.Doctor?.FullName</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-clock"></i> Ngay tao:</strong><br />
                                <span class="ms-4">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</span>
                            </p>
                            @if (isPaid && Model.PaidAt.HasValue)
                            {
                                <p class="mb-2">
                                    <strong><i class="bi bi-check-circle text-success"></i> Thanh toan:</strong><br />
                                    <span class="ms-4">@Model.PaidAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</span><br />
                                    <span class="ms-4"><small>Nguoi thu: <strong>@Model.PaidBy</strong></small></span>
                                </p>
                            }
                        </div>
                    </div>

                    <hr />

                    <h5 class="mb-3"><i class="bi bi-clipboard-check"></i> Chi tiet dich vu:</h5>

                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>STT</th>
                                    <th>Dich vu</th>
                                    <th>Loai</th>
                                    <th class="text-end">Don gia</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>1</td>
                                    <td><strong>Phi kham</strong></td>
                                    <td><span class="badge bg-primary">EXAM</span></td>
                                    <td class="text-end"><strong>@examFee.ToString("N0") VND</strong></td>
                                </tr>
                                @if (orders.Any())
                                {
                                    var stt = 2;
                                    @foreach (var order in orders)
                                    {
                                        <tr>
                                            <td>@stt</td>
                                            <td>@order.Service?.Name</td>
                                            <td>
                                                @if (order.Service?.Type == "LAB")
                                                {
                                                    <span class="badge bg-info text-dark">LAB</span>
                                                }
                                                else if (order.Service?.Type == "IMAGING")
                                                {
                                                    <span class="badge bg-warning text-dark">IMAGING</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@order.Service?.Type</span>
                                                }
                                            </td>
                                            <td class="text-end">@(order.Service?.Price ?? 0).ToString("N0") VND</td>
                                        </tr>
                                        stt++;
                                    }
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-success">
                                    <td colspan="3" class="text-end"><strong>Tong cong:</strong></td>
                                    <td class="text-end">
                                        <strong class="text-danger fs-4">@Model.TotalAmount.ToString("N0") VND</strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="alert alert-info mt-3">
                            <strong><i class="bi bi-info-circle"></i> Ghi chu:</strong><br />
                            @Model.Note
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-tools"></i> Thao tac</h5>
                </div>
                <div class="card-body">
                    @if (!isPaid)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i>
                            <strong>Chua thanh toan!</strong><br />
                            <small>Vui long thu tien tu benh nhan</small>
                        </div>

                        <form method="post" asp-action="Pay">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.InvoiceId" />
                            <button type="submit" class="btn btn-success w-100 btn-lg mb-3"
                                    onclick="return confirm('Xac nhan da thu tien: @Model.TotalAmount.ToString("N0") VND?')">
                                <i class="bi bi-cash"></i> THU TIEN
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle"></i>
                            <strong>Da thanh toan</strong><br />
                            <small>
                                Luc: @Model.PaidAt.Value.ToLocalTime().ToString("HH:mm:ss")<br />
                                Nguoi thu: <strong>@Model.PaidBy</strong>
                            </small>
                        </div>
                    }

                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-100 mb-2">
                        <i class="bi bi-arrow-left"></i> Ve danh sach
                    </a>

                    <button type="button" class="btn btn-outline-primary w-100" onclick="window.print()">
                        <i class="bi bi-printer"></i> In hoa don
                    </button>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header bg-secondary text-white">
                    <h6 class="mb-0"><i class="bi bi-info-circle"></i> Thong tin</h6>
                </div>
                <div class="card-body">
                    <small>
                        <p class="mb-2"><strong>Tong tien:</strong></p>
                        <ul class="mb-2">
                            <li>Phi kham: @examFee.ToString("N0") VND</li>
                            <li>Dich vu: @(Model.TotalAmount - examFee).ToString("N0") VND</li>
                        </ul>
                        
                        <p class="mb-0"><strong>Trang thai:</strong></p>
                        <ul class="mb-0">
                            <li>Encounter: Completed</li>
                            <li>Hoa don: @(isPaid ? "Paid" : "Unpaid")</li>
                        </ul>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        @@media print {
            .card-header,
            .btn,
            .alert,
            .sticky-top {
                display: none !important;
            }
            .card {
                border: none !important;
                box-shadow: none !important;
            }
        }
    </style>
}
