@model PendingPaymentViewModel
@{
    ViewData["Title"] = "Chờ thu chi phí cuoi";
}

<div class="container-fluid mt-4">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-hourglass-split"></i> Chờ thu chi phí cuoi</h2>
            <small class="text-muted">Bước 8 luồng KCB — BS đã chốt kham, BN can thanh toán CLS + thuốc</small>
        </div>
        <a href="@Url.Action("Index", new { type = "Final", status = "Unpaid" })" class="btn btn-primary">
            <i class="bi bi-receipt"></i> Tất cả HD Final chua thu
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-10">
                    <label class="form-label">Ngay check-in</label>
                    <input type="date" name="date" class="form-control" value="@Model.Date.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary d-block w-100"><i class="bi bi-search"></i> Loc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0"><i class="bi bi-list-check"></i> Đang cho thu (@Model.Encounters.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Encounters.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã luot</th>
                                <th>Bệnh nhân</th>
                                <th>Bác sĩ</th>
                                <th>Chẩn đoán / ICD</th>
                                <th>Check-in</th>
                                <th>Hoa don Final</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var enc in Model.Encounters)
                            {
                                Model.FinalInvoices.TryGetValue(enc.EncounterId, out var inv);
                                <tr>
                                    <td><strong>@(enc.EncounterCode ?? $"#{enc.EncounterId}")</strong></td>
                                    <td>
                                        <strong>@enc.Patient?.FullName</strong><br />
                                        <small class="text-muted">@enc.Patient?.Phone</small>
                                    </td>
                                    <td>@enc.Doctor?.FullName</td>
                                    <td>
                                        <small>@(enc.Diagnosis ?? "—")</small>
                                        @if (!string.IsNullOrEmpty(enc.Icd10Primary))
                                        {
                                            <br /><span class="badge bg-secondary">@enc.Icd10Primary</span>
                                        }
                                    </td>
                                    <td><small>@enc.CheckInAt.ToLocalTime().ToString("dd/MM HH:mm")</small></td>
                                    <td>
                                        @if (inv != null)
                                        {
                                            <strong class="text-danger">@inv.PatientAmount.ToString("N0") VND</strong><br />
                                            <small class="text-muted">@inv.InvoiceCode</small>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Chưa có HD</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (inv != null)
                                        {
                                            <a href="@Url.Action("Detail", new { id = inv.InvoiceId })" class="btn btn-sm btn-success">
                                                <i class="bi bi-cash"></i> Thu tien
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Lien he BS chot lai</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3">Không có BN nao cho thu chi phí cuoi hom nay</p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Pending", new { date = Model.Date.AddDays(-1).ToString("yyyy-MM-dd") })" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Ngày trước</a>
        <a href="@Url.Action("Pending")" class="btn btn-outline-secondary"><i class="bi bi-calendar-today"></i> Hom nay</a>
        <a href="@Url.Action("Pending", new { date = Model.Date.AddDays(1).ToString("yyyy-MM-dd") })" class="btn btn-outline-primary">Ngay sau <i class="bi bi-arrow-right"></i></a>
    </div>
</div>
