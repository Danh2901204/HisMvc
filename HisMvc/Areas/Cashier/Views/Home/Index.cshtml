@model InvoiceIndexViewModel
@{
    ViewData["Title"] = "Danh sách hóa đơn";
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-receipt"></i> Danh sách hóa đơn</h2>
        <div class="btn-group">
            <a href="@Url.Action("Index", new { status = "Unpaid", type = "ExamFee", date = Model.Date.ToString("yyyy-MM-dd") })" class="btn btn-outline-primary">
                <i class="bi bi-cash"></i> Phí khám chua thu
            </a>
            <a href="@Url.Action("Pending")" class="btn btn-warning">
                <i class="bi bi-hourglass-split"></i> Chờ thu chi phí cuoi
            </a>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Loai HD</label>
                    <select name="type" class="form-select">
                        <option value="">Tất cả</option>
                        <option value="ExamFee" selected="@(Model.CurrentType == "ExamFee")">Phí khám (buoc 2)</option>
                        <option value="Final" selected="@(Model.CurrentType == "Final")">Tổng hop (buoc 8)</option>
                        <option value="Inpatient" selected="@(Model.CurrentType == "Inpatient")">Noi tru</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Trạng thái</label>
                    <select name="status" class="form-select">
                        <option value="">Tất cả</option>
                        <option value="Unpaid" selected="@(Model.CurrentStatus == "Unpaid")">Chua thanh toán</option>
                        <option value="Paid" selected="@(Model.CurrentStatus == "Paid")">Đã thanh toán</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Ngay</label>
                    <input type="date" name="date" class="form-control" value="@Model.Date.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary d-block w-100"><i class="bi bi-search"></i> Loc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Hoa don (@Model.Invoices.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Invoices.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã HD</th>
                                <th>Loai</th>
                                <th>Bệnh nhân</th>
                                <th>Bác sĩ</th>
                                <th>Tổng tien</th>
                                <th>Trạng thái</th>
                                <th>Ngay tao</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in Model.Invoices)
                            {
                                var isPaid = inv.Status == InvoiceStatus.Paid;
                                <tr class="@(isPaid ? "table-success" : "")">
                                    <td><strong>@inv.InvoiceCode</strong></td>
                                    <td>
                                        <span class="badge @(inv.InvoiceType == InvoiceType.ExamFee ? "bg-primary" : inv.InvoiceType == InvoiceType.Final ? "bg-warning text-dark" : "bg-secondary")">
                                            @InvoiceDisplay.TypeLabel(inv.InvoiceType)
                                        </span>
                                    </td>
                                    <td>
                                        <strong>@inv.Encounter?.Patient?.FullName</strong><br />
                                        <small class="text-muted">@inv.Encounter?.Patient?.Phone</small>
                                    </td>
                                    <td>@inv.Encounter?.Doctor?.FullName</td>
                                    <td><strong class="text-danger">@inv.PatientAmount.ToString("N0") VND</strong></td>
                                    <td>
                                        @if (isPaid)
                                        { <span class="badge bg-success">Đã thu</span> }
                                        else
                                        { <span class="badge bg-warning text-dark">Chua thu</span> }
                                    </td>
                                    <td>
                                        <small>@inv.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</small>
                                        @if (isPaid && inv.PaidAt.HasValue)
                                        { <br /><small class="text-success">Thu: @inv.PaidAt.Value.ToLocalTime().ToString("HH:mm")</small> }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Detail", new { id = inv.InvoiceId })" class="btn btn-sm btn-info">
                                            <i class="bi bi-eye"></i> @(isPaid ? "Xem" : "Thu")
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted"><i class="bi bi-inbox" style="font-size: 3rem;"></i><p class="mt-3">Không có hóa đơn</p></div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Index", new { status = Model.CurrentStatus, type = Model.CurrentType, date = Model.Date.AddDays(-1).ToString("yyyy-MM-dd") })" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Ngày trước</a>
        <a href="@Url.Action("Index", new { status = Model.CurrentStatus, type = Model.CurrentType })" class="btn btn-outline-secondary"><i class="bi bi-calendar-today"></i> Hom nay</a>
        <a href="@Url.Action("Index", new { status = Model.CurrentStatus, type = Model.CurrentType, date = Model.Date.AddDays(1).ToString("yyyy-MM-dd") })" class="btn btn-outline-primary">Ngay sau <i class="bi bi-arrow-right"></i></a>
    </div>
</div>
