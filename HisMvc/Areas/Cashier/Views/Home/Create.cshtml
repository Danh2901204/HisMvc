@{
    ViewData["Title"] = "Tao hoa don";
    var encounter = (Encounter)ViewBag.Encounter;
    var orders = (List<Order>)ViewBag.Orders;
    var examFee = (decimal)ViewBag.ExamFee;
    var totalOrderPrice = (decimal)ViewBag.TotalOrderPrice;
    var totalAmount = (decimal)ViewBag.TotalAmount;
    var insuranceCalc = (InsuranceCalculationResult)ViewBag.InsuranceCalculation;
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-receipt"></i> Tao hoa don - Encounter #@encounter.EncounterId</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="mb-2">
                                <strong><i class="bi bi-person-fill text-primary"></i> Benh nhan:</strong><br />
                                <span class="ms-4 fs-5">@encounter.Patient?.FullName</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-telephone-fill text-success"></i> Dien thoai:</strong><br />
                                <span class="ms-4">@encounter.Patient?.Phone</span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2">
                                <strong><i class="bi bi-person-badge-fill text-info"></i> Bac si:</strong><br />
                                <span class="ms-4">@encounter.Doctor?.FullName</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-clock"></i> Thoi gian:</strong><br />
                                <span class="ms-4">@encounter.CheckInAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            </p>
                        </div>
                    </div>

                    <hr />

                    <h5 class="mb-3"><i class="bi bi-clipboard-check"></i> Chi tiet dich vu:</h5>

                    <div class="table-responsive mb-3">
                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>STT</th>
                                    <th>Dich vu</th>
                                    <th>Loai</th>
                                    <th class="text-end">Don gia</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>1</td>
                                    <td><strong>Phi kham</strong></td>
                                    <td><span class="badge bg-primary">EXAM</span></td>
                                    <td class="text-end"><strong>@examFee.ToString("N0") VND</strong></td>
                                </tr>
                                @if (orders.Any())
                                {
                                    var stt = 2;
                                    foreach (var order in orders)
                                    {
                                        <tr>
                                            <td>@stt</td>
                                            <td>@order.Service?.Name</td>
                                            <td>
                                                @if (order.Service?.Type == "LAB")
                                                {
                                                    <span class="badge bg-info text-dark">LAB</span>
                                                }
                                                else if (order.Service?.Type == "IMAGING")
                                                {
                                                    <span class="badge bg-warning text-dark">IMAGING</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@order.Service?.Type</span>
                                                }
                                            </td>
                                            <td class="text-end">@((order.Service?.Price ?? 0).ToString("N0")) VND</td>
                                        </tr>
                                        stt++;
                                    }
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-light">
                                    <td colspan="3" class="text-end"><strong>Tong cong:</strong></td>
                                    <td class="text-end">
                                        <strong class="text-danger fs-5">@totalAmount.ToString("N0") VND</strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <hr />

                    <!-- Thông tin BHYT -->
                    @if (insuranceCalc.HasInsurance)
                    {
                        <div class="card mb-3 @(insuranceCalc.IsValid ? "border-success" : "border-danger")">
                            <div class="card-header @(insuranceCalc.IsValid ? "bg-success" : "bg-danger") text-white">
                                <h5 class="mb-0"><i class="bi bi-shield-check"></i> Thông Tin B?o Hi?m Y T?</h5>
                            </div>
                            <div class="card-body">
                                @if (insuranceCalc.IsExpired)
                                {
                                    <div class="alert alert-danger">
                                        <i class="bi bi-exclamation-triangle"></i> 
                                        <strong>Th? BHYT ?ă h?t h?n!</strong> Không th? s? d?ng BHYT.
                                    </div>
                                }
                                else if (insuranceCalc.IsValid)
                                {
                                    <div class="row">
                                        <div class="col-md-6">
                                            <p class="mb-2"><strong>Mă th? BHYT:</strong> @insuranceCalc.InsuranceNumber</p>
                                            <p class="mb-2"><strong>Lo?i th?:</strong> @insuranceCalc.InsuranceType</p>
                                        </div>
                                        <div class="col-md-6">
                                            <p class="mb-2"><strong>T? l? chi tr?:</strong> <span class="badge bg-info">@insuranceCalc.CoveragePercent%</span></p>
                                            <p class="mb-2"><strong>Tr?ng thái:</strong> <span class="badge bg-success">H?p l?</span></p>
                                        </div>
                                    </div>
                                    
                                    <hr />
                                    
                                    <h6>Chi Ti?t Thanh Toán V?i BHYT:</h6>
                                    <table class="table table-sm table-bordered">
                                        <tr>
                                            <td><strong>T?ng chi phí:</strong></td>
                                            <td class="text-end">@insuranceCalc.TotalAmount.ToString("N0") VND</td>
                                        </tr>
                                        <tr class="table-success">
                                            <td><strong>BHYT chi tr? (@insuranceCalc.CoveragePercent%):</strong></td>
                                            <td class="text-end"><strong class="text-success">@insuranceCalc.InsurancePays.ToString("N0") VND</strong></td>
                                        </tr>
                                        <tr class="table-warning">
                                            <td><strong>B?nh nhân ??ng chi tr?:</strong></td>
                                            <td class="text-end"><strong class="text-danger">@insuranceCalc.PatientPays.ToString("N0") VND</strong></td>
                                        </tr>
                                    </table>
                                    
                                    <div class="alert alert-info mb-0">
                                        <i class="bi bi-info-circle"></i> 
                                        B?nh nhân ch? c?n thanh toán <strong>@insuranceCalc.PatientPays.ToString("N0") VND</strong>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <form method="post" asp-action="CreateInvoice">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="encounterId" value="@encounter.EncounterId" />

                        @if (insuranceCalc.HasInsurance && insuranceCalc.IsValid)
                        {
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" name="useInsurance" id="useInsurance" value="true" checked />
                                <label class="form-check-label" for="useInsurance">
                                    <strong>S? d?ng BHYT cho hóa ??n nŕy</strong>
                                </label>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label"><i class="bi bi-card-text"></i> Ghi chu:</label>
                            <textarea name="note" class="form-control" rows="3" 
                                      placeholder="Nhap ghi chu neu co..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Pending")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lai
                            </a>
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Tao hoa don
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
