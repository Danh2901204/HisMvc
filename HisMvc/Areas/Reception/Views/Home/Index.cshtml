@model List<HisMvc.Entities.Appointment>
@{
    ViewData["Title"] = "Lich hen";
    var d = (DateOnly)ViewBag.Date;
    var checkedInIds = (List<int>)ViewBag.CheckedInAppointments;
    var currentStatus = (string)ViewBag.CurrentStatus;
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-calendar-check"></i> Lich hen ngay @d.ToString("dd/MM/yyyy")</h2>
        <div>
            <a href="@Url.Action("Patients")" class="btn btn-info">
                <i class="bi bi-people"></i> Quan ly BN
            </a>
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Tao lich hen
            </a>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Chon ngay:</label>
                    <input type="date" name="date" class="form-control" value="@d.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Trang thai:</label>
                    <select name="status" class="form-select">
                        <option value="">Tat ca</option>
                        <option value="Booked" selected="@(currentStatus == "Booked")">Cho kham</option>
                        <option value="CheckedIn" selected="@(currentStatus == "CheckedIn")">Da check-in</option>
                        <option value="Cancelled" selected="@(currentStatus == "Cancelled")">Da huy</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary d-block w-100">
                        <i class="bi bi-search"></i> Tim kiem
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Danh sach lich hen (@Model.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ma</th>
                                <th><i class="bi bi-clock"></i> Gio</th>
                                <th><i class="bi bi-person"></i> Benh nhan</th>
                                <th><i class="bi bi-hospital"></i> Khoa</th>
                                <th><i class="bi bi-person-badge"></i> Bac si</th>
                                <th><i class="bi bi-info-circle"></i> Trang thai</th>
                                <th class="text-center">Thao tac</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model)
                            {
                                var isCheckedIn = checkedInIds.Contains(a.AppointmentId);
                                <tr class="@(isCheckedIn ? "table-success" : "")">
                                    <td><small class="text-muted">@a.Code</small></td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @a.TimeSlot?.Start.ToString("HH:mm") - @a.TimeSlot?.End.ToString("HH:mm")
                                        </span>
                                    </td>
                                    <td>
                                        <strong>@a.Patient?.FullName</strong><br />
                                        <small class="text-muted">
                                            <i class="bi bi-telephone"></i> @a.Patient?.Phone
                                        </small>
                                    </td>
                                    <td>@a.Department?.Name</td>
                                    <td>@a.Doctor?.FullName</td>
                                    <td>
                                        @if (isCheckedIn)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> Da check-in
                                            </span>
                                        }
                                        else if (a.Status == HisMvc.Entities.AppointmentStatus.Booked)
                                        {
                                            <span class="badge bg-warning text-dark">Cho kham</span>
                                        }
                                        else if (a.Status == HisMvc.Entities.AppointmentStatus.Cancelled)
                                        {
                                            <span class="badge bg-danger">Da huy</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@a.Status</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (a.Status == HisMvc.Entities.AppointmentStatus.Booked && !isCheckedIn)
                                        {
                                            <form method="post" asp-action="CheckIn" style="display: inline;">
                                                <input type="hidden" name="appointmentId" value="@a.AppointmentId" />
                                                <button type="submit" class="btn btn-sm btn-success" 
                                                        onclick="return confirm('Xac nhan check-in cho @a.Patient?.FullName?')">
                                                    <i class="bi bi-check-circle"></i> Check-in
                                                </button>
                                            </form>
                                            <form method="post" asp-action="Cancel" style="display: inline;">
                                                <input type="hidden" name="appointmentId" value="@a.AppointmentId" />
                                                <button type="submit" class="btn btn-sm btn-danger" 
                                                        onclick="return confirm('Xac nhan huy lich hen?')">
                                                    <i class="bi bi-x-circle"></i> Huy
                                                </button>
                                            </form>
                                        }
                                        else if (isCheckedIn)
                                        {
                                            <span class="badge bg-success">✓ Da vao kham</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x" style="font-size: 3rem; color: #ddd;"></i>
                    <p class="text-muted mt-3">Khong co lich hen nao</p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3 d-flex justify-content-between">
        <div>
            <a href="@Url.Action("Index", new { date = d.AddDays(-1).ToString("yyyy-MM-dd") })" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left"></i> Ngay truoc
            </a>
            <a href="@Url.Action("Index", new { date = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd") })" class="btn btn-outline-secondary">
                <i class="bi bi-calendar-today"></i> Hom nay
            </a>
            <a href="@Url.Action("Index", new { date = d.AddDays(1).ToString("yyyy-MM-dd") })" class="btn btn-outline-primary">
                Ngay sau <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</div>
