@model AppointmentListViewModel
@{
    ViewData["Title"] = "Lịch hẹn";
    var d = Model.SelectedDate;
    var checkedInIds = Model.CheckedInAppointmentIds;
    var currentStatus = Model.CurrentStatus;
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-calendar-check"></i> Lịch hẹn ngày @d.ToString("dd/MM/yyyy")</h2>
        <div>
            <a href="@Url.Action("Patients")" class="btn btn-info">
                <i class="bi bi-people"></i> Quản lý BN
            </a>
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Tạo lịch hẹn
            </a>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Chọn ngày:</label>
                    <input type="date" name="date" class="form-control" value="@d.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Trạng thái:</label>
                    <select name="status" class="form-select">
                        <option value="">Tất cả</option>
                        <option value="Booked" selected="@(currentStatus == "Booked")">Chờ khám</option>
                        <option value="CheckedIn" selected="@(currentStatus == "CheckedIn")">Đã check-in</option>
                        <option value="Cancelled" selected="@(currentStatus == "Cancelled")">Đã hủy</option>
                        <option value="NoShow" selected="@(currentStatus == "NoShow")">Không đến khám</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary d-block w-100">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Danh sách lịch hẹn (@Model.Appointments.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Appointments.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ma</th>
                                <th><i class="bi bi-clock"></i> Gio</th>
                                <th><i class="bi bi-person"></i> Bệnh nhân</th>
                                <th><i class="bi bi-hospital"></i> Khoa</th>
                                <th><i class="bi bi-person-badge"></i> Bác sĩ</th>
                                <th><i class="bi bi-info-circle"></i> Trạng thái</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model.Appointments)
                            {
                                var isCheckedIn = checkedInIds.Contains(a.AppointmentId);
                                <tr class="@(isCheckedIn ? "table-success" : "")">
                                    <td><small class="text-muted">@a.Code</small></td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @a.TimeSlot?.Start.ToString("HH:mm") - @a.TimeSlot?.End.ToString("HH:mm")
                                        </span>
                                    </td>
                                    <td>
                                        <strong>@a.Patient?.FullName</strong><br />
                                        <small class="text-muted">
                                            <i class="bi bi-telephone"></i> @a.Patient?.Phone
                                        </small>
                                    </td>
                                    <td>@a.Department?.Name</td>
                                    <td>@a.Doctor?.FullName</td>
                                    <td>
                                        @if (isCheckedIn)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> Đã check-in
                                            </span>
                                        }
                                        else if (a.Status == HisMvc.Entities.AppointmentStatus.Booked)
                                        {
                                            <span class="badge bg-warning text-dark">Chờ khám</span>
                                        }
                                        else if (a.IsCancelled)
                                        {
                                            <span class="badge bg-danger">Đã hủy</span>
                                            @if (a.CancelledAt.HasValue)
                                            {
                                                <br /><small class="text-muted">@a.CancelledAt.Value.ToLocalTime().ToString("dd/MM HH:mm")</small>
                                            }
                                        }
                                        else if (a.IsNoShow)
                                        {
                                            <span class="badge bg-secondary">Không đến khám</span>
                                            @if (a.NoShowAt.HasValue)
                                            {
                                                <br /><small class="text-muted">@a.NoShowAt.Value.ToLocalTime().ToString("dd/MM HH:mm")</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@a.Status</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (a.CanReceptionCancel && !isCheckedIn)
                                        {
                                            <form method="post" asp-action="CheckIn" style="display: inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="appointmentId" value="@a.AppointmentId" />
                                                <button type="submit" class="btn btn-sm btn-success"
                                                        onclick="return confirm('Xác nhận check-in cho @a.Patient?.FullName?')">
                                                    <i class="bi bi-check-circle"></i> Check-in
                                                </button>
                                            </form>
                                            <form method="post" asp-action="Cancel" style="display: inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="appointmentId" value="@a.AppointmentId" />
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Xác nhận huy lịch hẹn?')">
                                                    <i class="bi bi-x-circle"></i> Hủy
                                                </button>
                                            </form>
                                        }
                                        else if (isCheckedIn)
                                        {
                                            <span class="badge bg-success">✓ Đã vào khám</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x" style="font-size: 3rem; color: #ddd;"></i>
                    <p class="text-muted mt-3">Không có lịch hẹn nao</p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3 d-flex justify-content-between">
        <div>
            <a href="@Url.Action("Index", new { date = d.AddDays(-1).ToString("yyyy-MM-dd") })" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left"></i> Ngày trước
            </a>
            <a href="@Url.Action("Index", new { date = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd") })" class="btn btn-outline-secondary">
                <i class="bi bi-calendar-today"></i> Hom nay
            </a>
            <a href="@Url.Action("Index", new { date = d.AddDays(1).ToString("yyyy-MM-dd") })" class="btn btn-outline-primary">
                Ngay sau <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</div>
