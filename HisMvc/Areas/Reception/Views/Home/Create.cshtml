@{
    ViewData["Title"] = "Tao lich hen";
}

<div class="container-fluid mt-4 pb-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Tao lich hen moi</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <h5 class="mb-3 text-primary"><i class="bi bi-person-circle"></i> Thong tin benh nhan</h5>
                        <partial name="_PatientFormFieldsLoose" />

                        <hr class="my-4" />

                        <h5 class="mb-3 text-primary"><i class="bi bi-calendar-check"></i> Thong tin lich hen</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Khoa kham <span class="text-danger">*</span></label>
                                <select name="departmentId" class="form-select" required>
                                    <option value="">-- Chon khoa --</option>
                                    @foreach (var d in ViewBag.Departments)
                                    {
                                        <option value="@d.Value">@d.Text</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bac si <span class="text-danger">*</span></label>
                                <select name="doctorId" class="form-select" required>
                                    <option value="">-- Chon bac si --</option>
                                    @foreach (var d in ViewBag.Doctors)
                                    {
                                        <option value="@d.Value">@d.Text</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Ngay kham <span class="text-danger">*</span></label>
                                <input type="date" name="date" class="form-control"
                                       value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Khung gio <span class="text-danger">*</span></label>
                                <select name="slotId" class="form-select" required>
                                    <option value="">-- Chon gio --</option>
                                    @foreach (var s in ViewBag.Slots)
                                    {
                                        <option value="@s.Value">@s.Text</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ghi chu</label>
                            <textarea name="note" class="form-control" rows="3"
                                      placeholder="Nhap ghi chu neu co..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lai
                            </a>
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Tao lich hen
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const patientFieldIds = [
        'fullName', 'dob', 'gender', 'identityNumber', 'address',
        'insuranceNumber', 'insuranceType', 'insuranceExpiry',
        'insuranceCoveragePercent', 'insuranceHospital'
    ];

    function setField(id, value) {
        const el = document.getElementById(id);
        if (!el) return;
        el.value = value ?? '';
    }

    function clearPatientFields() {
        patientFieldIds.forEach(id => setField(id, ''));
        setField('insuranceCoveragePercent', '0');
        setField('gender', '0');
    }

    function fillPatientFields(data) {
        setField('fullName', data.fullName);
        setField('dob', data.dob);
        if (data.gender !== undefined && data.gender !== null && data.gender !== '') {
            const genderMap = { 'Male': '1', 'Female': '2', 'Other': '3', 'Unknown': '0' };
            setField('gender', genderMap[data.gender] ?? String(data.gender));
        }
        setField('identityNumber', data.identityNumber);
        setField('address', data.address);
        setField('insuranceNumber', data.insuranceNumber);
        setField('insuranceType', data.insuranceType);
        setField('insuranceExpiry', data.insuranceExpiry);
        setField('insuranceCoveragePercent', data.insuranceCoveragePercent ?? '0');
        setField('insuranceHospital', data.insuranceHospital);
    }

    function searchPatient() {
        const phone = document.getElementById('phone').value.trim();
        if (!phone) {
            alert('Vui long nhap so dien thoai!');
            return;
        }

        fetch(`/Reception/Home/SearchPatient?phone=${encodeURIComponent(phone)}`)
            .then(res => res.json())
            .then(data => {
                if (data.found) {
                    fillPatientFields(data);
                    alert('Da tim thay thong tin benh nhan!');
                } else {
                    clearPatientFields();
                    alert('Khong tim thay benh nhan. Vui long nhap thong tin moi.');
                }
            })
            .catch(err => {
                console.error(err);
                alert('Co loi xay ra khi tim kiem!');
            });
    }
</script>
}
