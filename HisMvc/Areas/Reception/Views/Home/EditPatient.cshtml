@model Patient
@{
    ViewData["Title"] = "Sua Thong Tin Benh Nhan";
}

<div class="container-fluid mt-4 pb-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Sua Thong Tin Benh Nhan #@Model.PatientId</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="PatientId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="alert alert-secondary py-2">
                            <i class="bi bi-hash"></i> Ma benh nhan: <strong>@Model.PatientId</strong> (khong doi)
                        </div>

                        <partial name="_PatientFormFields" model="Model" />

                        <div class="alert alert-info mt-3 mb-0">
                            <i class="bi bi-info-circle"></i>
                            <strong>Luu y:</strong> Thay doi thong tin benh nhan se anh huong den lich hen va ho so lien quan.
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="@Url.Action("Patients")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lai
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-circle"></i> Cap nhat
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
