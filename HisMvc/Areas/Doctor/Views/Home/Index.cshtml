@model List<HisMvc.Entities.Encounter>
@{
    ViewData["Title"] = "Danh sach luot kham";
    var currentStatus = (string)ViewBag.CurrentStatus ?? "";
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-clipboard2-pulse"></i> Danh sach luot kham</h2>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-8">
                    <label class="form-label">Loc theo trang thai:</label>
                    <select name="status" class="form-select" onchange="this.form.submit()">
                        <option value="">Tat ca</option>
                        <option value="CheckedIn" selected="@(currentStatus == "CheckedIn")">Dang cho kham</option>
                        <option value="InService" selected="@(currentStatus == "InService")">Dang kham</option>
                        <option value="Completed" selected="@(currentStatus == "Completed")">Da hoan thanh</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary d-block w-100">
                        <i class="bi bi-search"></i> Loc
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Quan ly luot kham benh (@Model.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th><i class="bi bi-person"></i> Benh nhan</th>
                                <th><i class="bi bi-person-badge"></i> Bac si</th>
                                <th><i class="bi bi-info-circle"></i> Trang thai</th>
                                <th><i class="bi bi-clock-history"></i> Check-in</th>
                                <th><i class="bi bi-file-medical"></i> Chan doan</th>
                                <th class="text-center">Thao tac</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in Model)
                            {
                                var statusClass = e.Status == HisMvc.Entities.EncounterStatus.CheckedIn ? "table-info" :
                                                  e.Status == HisMvc.Entities.EncounterStatus.InService ? "table-warning" :
                                                  e.Status == HisMvc.Entities.EncounterStatus.Completed ? "table-success" : "";
                                
                                <tr class="@statusClass">
                                    <td><strong>#@e.EncounterId</strong></td>
                                    <td>
                                        <strong>@e.Patient?.FullName</strong><br />
                                        <small class="text-muted">
                                            <i class="bi bi-telephone"></i> @e.Patient?.Phone
                                        </small>
                                    </td>
                                    <td>
                                        @e.Doctor?.FullName
                                        @if (e.Appointment != null)
                                        {
                                            <br /><small class="text-muted">@e.Appointment.Code</small>
                                        }
                                    </td>
                                    <td>
                                        @if (e.Status == HisMvc.Entities.EncounterStatus.CheckedIn)
                                        {
                                            <span class="badge bg-info">
                                                <i class="bi bi-hourglass-split"></i> Dang cho kham
                                            </span>
                                        }
                                        else if (e.Status == HisMvc.Entities.EncounterStatus.InService)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-activity"></i> Dang kham
                                            </span>
                                        }
                                        else if (e.Status == HisMvc.Entities.EncounterStatus.Completed)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> Hoan thanh
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@e.Status</span>
                                        }
                                    </td>
                                    <td>
                                        <small>@e.CheckInAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                                        @if (e.Status == HisMvc.Entities.EncounterStatus.Completed)
                                        {
                                            <br /><small class="text-success">
                                                <i class="bi bi-check"></i> @e.EndAt.ToLocalTime().ToString("HH:mm")
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(e.Diagnosis))
                                        {
                                            <small title="@e.Diagnosis">
                                                @(e.Diagnosis.Length > 30 ? e.Diagnosis.Substring(0, 30) + "..." : e.Diagnosis)
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chua co</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (e.Status != HisMvc.Entities.EncounterStatus.Completed)
                                        {
                                            <a href="@Url.Action("Examine", new { id = e.EncounterId })" class="btn btn-sm btn-primary">
                                                <i class="bi bi-stethoscope"></i> Kham
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("Examine", new { id = e.EncounterId })" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i> Xem
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size: 3rem; color: #ddd;"></i>
                    <p class="text-muted mt-3">
                        @if (string.IsNullOrEmpty(currentStatus))
                        {
                            <text>Chua co luot kham nao</text>
                        }
                        else
                        {
                            <text>Khong co luot kham voi trang thai nay</text>
                        }
                    </p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <div class="card">
            <div class="card-body">
                <h6>Chu thich trang thai:</h6>
                <div class="d-flex gap-3 flex-wrap">
                    <div>
                        <span class="badge bg-info">Dang cho kham</span> - Benh nhan da check-in, cho bac si kham
                    </div>
                    <div>
                        <span class="badge bg-warning text-dark">Dang kham</span> - Bac si dang kham, nhap thong tin
                    </div>
                    <div>
                        <span class="badge bg-success">Hoan thanh</span> - Da chot luot kham, khong sua duoc
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
