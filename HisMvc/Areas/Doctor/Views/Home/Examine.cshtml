@using HisMvc.Entities
@model ExamineViewModel
@{
    ViewData["Title"] = "Khám bệnh";
    var enc = Model.Encounter;
    var status = enc.Status;
    var isCompleted = status == EncounterStatus.Completed || status == EncounterStatus.Cancelled;
    var orders = Model.Orders;
    var pendingOrders = orders.Where(o => o.Status == OrderStatus.Requested || o.Status == OrderStatus.InProgress).ToList();
    var allergies = Model.Allergies;
    var histories = Model.MedicalHistories;
    var previousEncounters = Model.PreviousEncounters;
    var hasSevereAllergy = allergies.Any(a => a.Severity == AllergySeverity.Severe);
    var prescription = Model.Prescription;
    var canPrescribe = status == EncounterStatus.InService || status == EncounterStatus.WaitingResult;
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (allergies.Any() || histories.Any())
    {
        <div class="alert @(hasSevereAllergy ? "alert-danger" : "alert-warning") d-flex align-items-start mb-3">
            <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
            <div class="flex-grow-1">
                <h5 class="alert-heading mb-2">@(hasSevereAllergy ? "CANH BAO NGHIEM TRONG" : "Lưu ý trước khi kham/ke don")</h5>
                @if (allergies.Any())
                {
                    <div class="mb-2">
                        <strong>Dị ứng:</strong>
                        @foreach (var a in allergies)
                        {
                            var sev = a.Severity switch { AllergySeverity.Severe => "bg-danger", AllergySeverity.Moderate => "bg-warning text-dark", _ => "bg-info" };
                            <span class="badge @sev me-1" title="@(a.Reaction ?? "")">@a.Allergen — @a.Severity</span>
                        }
                    </div>
                }
                @if (histories.Any())
                {
                    <div><strong>Tien su:</strong>
                        @foreach (var h in histories) { <span class="badge bg-secondary me-1">@h.Condition (@h.DiagnosedDate.ToString("yyyy"))</span> }
                    </div>
                }
            </div>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-stethoscope"></i> @(enc.EncounterCode ?? $"Encounter #{enc.EncounterId}")
                        @if (enc.QueueNumber.HasValue) { <span class="badge bg-light text-dark ms-2">STT @enc.QueueNumber</span> }
                    </h4>
                    @{
                        string statusBadge = status switch
                        {
                            EncounterStatus.CheckedIn => "<span class='badge bg-secondary'>Chờ thu phi kham</span>",
                            EncounterStatus.WaitingExam => "<span class='badge bg-info'>Đã thu phi - cho goi</span>",
                            EncounterStatus.InService => "<span class='badge bg-warning text-dark'>Đang kham</span>",
                            EncounterStatus.WaitingResult => "<span class='badge bg-info'>Chờ ket qua CLS</span>",
                            EncounterStatus.WaitingFinalPayment => "<span class='badge bg-warning text-dark'>Chờ thu chi phí cuoi</span>",
                            EncounterStatus.WaitingMedicine => "<span class='badge bg-success'>Chờ linh thuốc</span>",
                            EncounterStatus.Completed => "<span class='badge bg-success'>Hoàn thành</span>",
                            EncounterStatus.Cancelled => "<span class='badge bg-danger'>Đã huy</span>",
                            _ => $"<span class='badge bg-secondary'>{status}</span>"
                        };
                    }
                    @Html.Raw(statusBadge)
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>BN:</strong> @enc.Patient?.FullName · SDT @enc.Patient?.Phone</p>
                            @if (enc.Patient?.Dob != null)
                            { <p class="mb-1"><strong>Tuổi:</strong> @((DateTime.Today.Year - enc.Patient.Dob.Value.Year))</p> }
                            @if (!string.IsNullOrEmpty(enc.Patient?.InsuranceNumber))
                            { <p class="mb-1"><strong>BHYT:</strong> @enc.Patient.InsuranceNumber (@enc.Patient.InsuranceCoveragePercent%)</p> }
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1"><strong>BS:</strong> @enc.Doctor?.FullName</p>
                            <p class="mb-1"><strong>Check-in:</strong> @enc.CheckInAt.ToLocalTime():dd/MM HH:mm</p>
                            @if (enc.StartedAt.HasValue) { <p class="mb-1"><strong>Goi vào luc:</strong> @enc.StartedAt.Value.ToLocalTime():HH:mm</p> }
                        </div>
                    </div>

                    @if (status == EncounterStatus.WaitingExam)
                    {
                        <div class="alert alert-warning d-flex justify-content-between align-items-center">
                            <div>BN da thanh toán phi kham, Đang xếp hàng STT <strong>@enc.QueueNumber</strong>. Bam <em>Gọi BN</em> de bat dau kham.</div>
                            <form method="post" asp-action="CallPatient" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@enc.EncounterId" />
                                <input type="text" name="roomNumber" placeholder="Phong" class="form-control form-control-sm" style="width:90px" value="@(enc.RoomNumber ?? "")" />
                                <button class="btn btn-success btn-sm"><i class="bi bi-megaphone"></i> Gọi BN</button>
                            </form>
                        </div>
                    }

                    <hr />

                    <form method="post" asp-action="Save">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@enc.EncounterId" />

                        @if (canPrescribe)
                        {
                            <div class="mb-3 position-relative">
                                <label class="form-label small"><strong>Tim chẩn đoán ICD-10</strong></label>
                                <input type="text" id="icdSearch" class="form-control" placeholder="Go tên bệnh (vd: tang huyet ap, viem da day) hoặc ma (I10)..." autocomplete="off" />
                                <div id="icdDropdown" class="list-group position-absolute w-100 shadow-sm icd-dropdown"></div>
                                <small class="text-muted">Chọn tu gọi y — không can nho ma. Hoặc ghi chẩn đoán kem ma (vd: I10 - Tang huyet ap).</small>
                            </div>
                        }

                        <div class="row g-2 mb-2">
                            <div class="col-md-3">
                                <label class="form-label small"><strong>ICD-10 chinh</strong> <span class="text-danger">*</span></label>
                                <input name="icd10Primary" id="icd10Primary" value="@enc.Icd10Primary" maxlength="10" class="form-control text-uppercase bg-light" placeholder="Tu dong" readonly />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label small"><strong>Tên benh chinh</strong></label>
                                <input name="icd10PrimaryName" id="icd10PrimaryName" value="@enc.Icd10PrimaryName" maxlength="200" class="form-control bg-light" placeholder="Tu dong" readonly />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small"><strong>ICD-10 kem theo</strong></label>
                                <input name="icd10Secondary" id="icd10Secondary" value="@enc.Icd10Secondary" maxlength="50" class="form-control text-uppercase bg-light" placeholder="Tu dong" readonly />
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label small"><strong>Chẩn đoán</strong> <span class="text-danger">*</span></label>
                            <input name="diagnosis" id="diagnosisInput" value="@enc.Diagnosis" class="form-control" placeholder="VD: I10 - Tang huyet ap man tinh / K29.5 - Viem da day" @(canPrescribe ? "" : "readonly") />
                        </div>

                        <div class="mb-2">
                            <label class="form-label small"><strong>Ket luan</strong></label>
                            <textarea name="conclusion" rows="3" class="form-control" @(canPrescribe ? "" : "readonly")>@enc.Conclusion</textarea>
                        </div>

                        <div class="row g-2 mb-2">
                            <div class="col-md-8">
                                <label class="form-label small"><strong>Dan do BN</strong></label>
                                <textarea name="instructions" rows="2" class="form-control" @(canPrescribe ? "" : "readonly")>@enc.Instructions</textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small"><strong>Hen tai kham</strong></label>
                                <input type="date" name="followUpDate" value="@(enc.FollowUpDate?.ToString("yyyy-MM-dd"))" class="form-control" @(canPrescribe ? "" : "readonly") />
                            </div>
                        </div>

                        @if (canPrescribe)
                        {
                            <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Luu thông tin khám</button>
                        }
                    </form>
                </div>
            </div>

            <!-- Chỉ định CLS -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-clipboard-check"></i> Chỉ định can lam sang
                        @if (pendingOrders.Any()) { <span class="badge bg-warning text-dark float-end">@pendingOrders.Count cho KQ</span> }
                    </h5>
                </div>
                <div class="card-body">
                    @if (canPrescribe)
                    {
                        <form method="post" asp-action="AddOrder" class="mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="encounterId" value="@enc.EncounterId" />
                            <div class="row g-2">
                                <div class="col-md-7">
                                    <select name="serviceId" class="form-select" required>
                                        <option value="">-- Chọn DV CLS --</option>
                                        @foreach (var s in Model.Services)
                                        { <option value="@s.Value">@s.Text</option> }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <input type="number" name="quantity" value="1" min="1" class="form-control" placeholder="SL" />
                                </div>
                                <div class="col-md-3">
                                    <button class="btn btn-primary w-100"><i class="bi bi-plus-circle"></i> Chỉ định</button>
                                </div>
                            </div>
                        </form>
                    }

                    @if (orders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-hover mb-0">
                                <thead class="table-light">
                                    <tr><th>Dịch vụ</th><th>SL</th><th>Trạng thái</th><th>Kết quả</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in orders)
                                    {
                                        <tr class="@(o.Status == OrderStatus.Resulted ? "table-success" : "")">
                                            <td>@o.Service?.Name <small class="text-muted">(@o.Service?.Type)</small></td>
                                            <td>@o.Quantity</td>
                                            <td>
                                                @switch (o.Status)
                                                {
                                                    case OrderStatus.Requested: <span class="badge bg-warning text-dark">Cho</span> break;
                                                    case OrderStatus.InProgress: <span class="badge bg-info">Đang lam</span> break;
                                                    case OrderStatus.Resulted: <span class="badge bg-success">Co KQ</span> break;
                                                    case OrderStatus.Cancelled: <span class="badge bg-danger">Hủy</span> break;
                                                }
                                            </td>
                                            <td>
                                                @if (o.OrderResult != null)
                                                { <small>@o.OrderResult.ResultText</small> }
                                                else
                                                { <small class="text-muted">—</small> }
                                            </td>
                                            <td>
                                                @if (canPrescribe && (o.Status == OrderStatus.Requested || o.Status == OrderStatus.InProgress))
                                                {
                                                    <form method="post" asp-action="CancelOrder">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="orderId" value="@o.OrderId" />
                                                        <input type="hidden" name="encounterId" value="@enc.EncounterId" />
                                                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Hủy chi dinh?')"><i class="bi bi-x"></i></button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">Chưa có chi dinh CLS.</div>
                    }
                </div>
            </div>

            <!-- Kê đơn thuốc -->
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-capsule"></i> Kê đơn thuốc</h5>
                </div>
                <div class="card-body">
                    @if (prescription == null)
                    {
                        @if (canPrescribe)
                        {
                            <form method="post" asp-action="CreatePrescription">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="encounterId" value="@enc.EncounterId" />
                                <button class="btn btn-outline-success"><i class="bi bi-plus-circle"></i> Tạo đơn thuốc</button>
                            </form>
                        }
                        else
                        {
                            <div class="text-muted small">Chưa có đơn thuốc.</div>
                        }
                    }
                    else
                    {
                        <p class="mb-2 small">Don @prescription.Code · @prescription.Status</p>

                        @if (prescription.Items.Any())
                        {
                            <table class="table table-sm table-bordered mb-3">
                                <thead class="table-light"><tr><th>Thuốc</th><th>SL</th><th>Lieu dung</th><th>Ngay</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var it in prescription.Items)
                                    {
                                        <tr>
                                            <td>@it.Medicine?.Name <small class="text-muted">@it.Medicine?.Unit</small></td>
                                            <td>@it.Quantity</td>
                                            <td>@it.Dosage</td>
                                            <td>@it.Duration</td>
                                            <td>
                                                @if (canPrescribe && prescription.Status == PrescriptionStatus.Pending)
                                                {
                                                    <form method="post" asp-action="RemoveMedicine">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="itemId" value="@it.PrescriptionItemId" />
                                                        <input type="hidden" name="encounterId" value="@enc.EncounterId" />
                                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-x"></i></button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }

                        @if (canPrescribe && prescription.Status == PrescriptionStatus.Pending)
                        {
                            <form method="post" asp-action="AddMedicine" class="row g-2 align-items-end">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="prescriptionId" value="@prescription.PrescriptionId" />
                                <div class="col-md-4">
                                    <label class="form-label small">Thuốc</label>
                                    <select name="medicineId" class="form-select" required>
                                        <option value="">-- Chọn thuốc --</option>
                                        @foreach (var m in Model.Medicines)
                                        { <option value="@m.Value">@m.Text</option> }
                                    </select>
                                </div>
                                <div class="col-md-1">
                                    <label class="form-label small">SL</label>
                                    <input type="number" name="quantity" min="1" value="1" class="form-control" required />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Lieu dung</label>
                                    <input name="dosage" class="form-control" placeholder="VD: 1v x 3 lan/ngày" required />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small">Ngay</label>
                                    <input type="number" name="duration" min="1" value="3" class="form-control" />
                                </div>
                                <div class="col-md-2">
                                    <button class="btn btn-success w-100"><i class="bi bi-plus"></i> Them</button>
                                </div>
                                <div class="col-12">
                                    <input name="instructions" class="form-control form-control-sm" placeholder="Huong dan (vd: uong sau an)" />
                                </div>
                            </form>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar Thao tác -->
        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-dark text-white"><h5 class="mb-0"><i class="bi bi-tools"></i> Thao tác</h5></div>
                <div class="card-body">
                    @if (canPrescribe)
                    {
                        <div class="alert alert-warning small mb-3">
                            <strong>Dieu kien chot kham:</strong><br />
                            • Co chẩn đoán + ICD-10<br />
                            • Tất cả chi dinh đã có KQ
                        </div>

                        @if (pendingOrders.Any())
                        {
                            <div class="alert alert-danger small">Còn @pendingOrders.Count chi dinh chưa có KQ!</div>
                        }
                        @if (string.IsNullOrEmpty(enc.Diagnosis))
                        {
                            <div class="alert alert-danger small">Chưa có chẩn đoán!</div>
                        }
                        @if (string.IsNullOrEmpty(enc.Icd10Primary))
                        {
                            <div class="alert alert-danger small">Chưa có ICD-10 benh chinh!</div>
                        }

                        <form method="post" asp-action="Close">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@enc.EncounterId" />
                            <button class="btn btn-danger w-100 mb-3" onclick="return confirm('CHOT lượt khám? BN sẽ chuyển sang Thu ngan thu chi phí phát sinh.')">
                                <i class="bi bi-lock"></i> CHOT lượt khám
                            </button>
                        </form>
                    }
                    else if (status == EncounterStatus.WaitingFinalPayment)
                    {
                        <div class="alert alert-info small">BN đang chờ Thu ngân thu chi phí cuối. Có thể mở lại nếu chưa thanh toán.</div>
                        <form method="post" asp-action="Reopen">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@enc.EncounterId" />
                            <button class="btn btn-warning w-100"><i class="bi bi-unlock"></i> Mo lai</button>
                        </form>
                    }
                    else if (status == EncounterStatus.Completed)
                    {
                        <div class="alert alert-success small">Lượt khám hoàn thành @enc.EndAt.ToLocalTime().ToString("dd/MM HH:mm").</div>
                    }

                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-100 mt-2"><i class="bi bi-arrow-left"></i> Quay lại danh sach</a>
                </div>
            </div>

            @if (previousEncounters.Any())
            {
                <div class="card shadow-sm mt-3">
                    <div class="card-header bg-info text-white"><h6 class="mb-0">Lịch sử kham</h6></div>
                    <div class="card-body p-2">
                        @foreach (var prev in previousEncounters)
                        {
                            <div class="border-start border-3 border-info ps-2 mb-2 small">
                                <strong>@prev.EndAt.ToLocalTime().ToString("dd/MM/yyyy")</strong>
                                — BS @prev.Doctor?.FullName<br />
                                <span class="text-muted">@(prev.Diagnosis ?? "—") @(string.IsNullOrEmpty(prev.Icd10Primary) ? "" : $"({prev.Icd10Primary})")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (canPrescribe)
{
    <style>
        .icd-dropdown { display: none; z-index: 1050; max-height: 240px; overflow-y: auto; }
        .icd-dropdown.show { display: block; }
        .icd-dropdown .list-group-item { cursor: pointer; font-size: 0.9rem; }
        .icd-dropdown .list-group-item:hover { background: #e7f1ff; }
        .icd-dropdown .icd-code { font-weight: 600; color: #0d6efd; min-width: 4rem; display: inline-block; }
    </style>
    <script>
        (function () {
            const searchUrl = '@Url.Action("SearchIcd10", "Home", new { area = "Doctor" })';
            const parseUrl = '@Url.Action("ParseIcd10", "Home", new { area = "Doctor" })';
            const searchInput = document.getElementById('icdSearch');
            const dropdown = document.getElementById('icdDropdown');
            const primary = document.getElementById('icd10Primary');
            const primaryName = document.getElementById('icd10PrimaryName');
            const secondary = document.getElementById('icd10Secondary');
            const diagnosisInput = document.getElementById('diagnosisInput');
            let debounceTimer;

            function fillIcd(code, name, sec) {
                if (primary) primary.value = code || '';
                if (primaryName) primaryName.value = name || '';
                if (sec !== undefined && secondary && !secondary.value.trim())
                    secondary.value = sec || '';
            }

            function hideDropdown() {
                dropdown?.classList.remove('show');
            }

            function showResults(items) {
                if (!dropdown) return;
                dropdown.innerHTML = '';
                if (!items.length) {
                    dropdown.innerHTML = '<div class="list-group-item text-muted small">Không tìm thay — thu gọi tu khac hoặc ghi chẩn đoán kem ma.</div>';
                } else {
                    items.forEach(item => {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action';
                        btn.innerHTML = `<span class="icd-code">${item.code}</span> ${item.name}` +
                            (item.chapter ? ` <small class="text-muted">(${item.chapter})</small>` : '');
                        btn.addEventListener('click', () => {
                            fillIcd(item.code, item.name);
                            if (diagnosisInput && !diagnosisInput.value.trim())
                                diagnosisInput.value = `${item.code} - ${item.name}`;
                            hideDropdown();
                            searchInput.value = '';
                        });
                        dropdown.appendChild(btn);
                    });
                }
                dropdown.classList.add('show');
            }

            async function fetchIcd(q) {
                const res = await fetch(`${searchUrl}?q=${encodeURIComponent(q)}`);
                return res.json();
            }

            async function parseFromDiagnosis(force) {
                const dx = diagnosisInput?.value?.trim() || '';
                if (!dx) return;
                if (!force && primary?.value?.trim()) return;
                const res = await fetch(`${parseUrl}?diagnosis=${encodeURIComponent(dx)}`);
                const data = await res.json();
                if (data.primaryCode) {
                    fillIcd(data.primaryCode, data.primaryName || '', data.secondaryCodes || '');
                }
            }

            searchInput?.addEventListener('input', () => {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(async () => {
                    const q = searchInput.value.trim();
                    const items = await fetchIcd(q);
                    showResults(items);
                }, 250);
            });

            searchInput?.addEventListener('focus', async () => {
                const items = await fetchIcd(searchInput.value.trim());
                showResults(items);
            });

            document.addEventListener('click', e => {
                if (!dropdown?.contains(e.target) && e.target !== searchInput)
                    hideDropdown();
            });

            diagnosisInput?.addEventListener('blur', () => parseFromDiagnosis(false));

            document.querySelector('form[action*="Save"]')?.addEventListener('submit', () => {
                if (!primary?.value?.trim() && diagnosisInput?.value?.trim()) {
                    const m = diagnosisInput.value.match(/\b([A-TV-Z][0-9]{2}(?:\.[0-9]{1,2})?)\b/i);
                    if (m) primary.value = m[1].toUpperCase();
                }
            });

            parseFromDiagnosis(false);
        })();
    </script>
}
