@model HisMvc.Entities.Encounter
@{
    ViewData["Title"] = "Kham benh";
    var isCompleted = Model.Status == HisMvc.Entities.EncounterStatus.Completed;
    var orders = (List<HisMvc.Entities.Order>)ViewBag.Orders;
    var pendingOrders = orders.Where(o => o.Status == HisMvc.Entities.OrderStatus.Requested).ToList();
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-stethoscope"></i> Kham benh - Encounter #@Model.EncounterId
                        @if (isCompleted)
                        {
                            <span class="badge bg-success float-end">
                                <i class="bi bi-lock"></i> Da chot
                            </span>
                        }
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="mb-2">
                                <strong><i class="bi bi-person-fill text-primary"></i> Benh nhan:</strong><br />
                                <span class="ms-4 fs-5">@Model.Patient?.FullName</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-telephone-fill text-success"></i> Dien thoai:</strong><br />
                                <span class="ms-4">@Model.Patient?.Phone</span>
                            </p>
                            @if (Model.Patient?.Dob != null)
                            {
                                <p class="mb-2">
                                    <strong><i class="bi bi-calendar"></i> Ngay sinh:</strong><br />
                                    <span class="ms-4">
                                        @Model.Patient.Dob.Value.ToString("dd/MM/yyyy")
                                        (@((DateTime.Today.Year - Model.Patient.Dob.Value.Year)) tuoi)
                                    </span>
                                </p>
                            }
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2">
                                <strong><i class="bi bi-person-badge-fill text-info"></i> Bac si kham:</strong><br />
                                <span class="ms-4">@Model.Doctor?.FullName</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-clock-history"></i> Check-in:</strong><br />
                                <span class="ms-4">@Model.CheckInAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-info-circle-fill text-warning"></i> Trang thai:</strong><br />
                                <span class="ms-4">
                                    @if (Model.Status == HisMvc.Entities.EncounterStatus.CheckedIn)
                                    {
                                        <span class="badge bg-info">
                                            <i class="bi bi-hourglass-split"></i> Dang cho kham
                                        </span>
                                    }
                                    else if (Model.Status == HisMvc.Entities.EncounterStatus.InService)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-activity"></i> Dang kham
                                        </span>
                                    }
                                    else if (Model.Status == HisMvc.Entities.EncounterStatus.Completed)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Hoan thanh
                                        </span>
                                        @if (Model.EndAt != default)
                                        {
                                            <br /><small class="ms-4">Chot luc: @Model.EndAt.ToLocalTime().ToString("HH:mm:ss")</small>
                                        }
                                    }
                                </span>
                            </p>
                        </div>
                    </div>

                    <hr />

                    <form method="post" asp-action="Save">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.EncounterId" />

                        <div class="mb-3">
                            <label class="form-label">
                                <strong><i class="bi bi-clipboard-pulse"></i> Chan doan</strong>
                                @if (!isCompleted)
                                {
                                    <span class="text-danger">*</span>
                                }
                            </label>
                            <input name="diagnosis" value="@Model.Diagnosis" 
                                   class="form-control @(!isCompleted && string.IsNullOrEmpty(Model.Diagnosis) ? "border-danger" : "")" 
                                   placeholder="Nhap chan doan benh (bat buoc truoc khi chot)"
                                   @(isCompleted ? "readonly" : "") />
                            @if (!isCompleted && string.IsNullOrEmpty(Model.Diagnosis))
                            {
                                <small class="text-danger">Vui long nhap chan doan truoc khi chot luot kham</small>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                <strong><i class="bi bi-card-text"></i> Ket luan / Dan do</strong>
                            </label>
                            <textarea name="conclusion" rows="4" 
                                      class="form-control" 
                                      placeholder="Nhap ket luan va loi dan cho benh nhan"
                                      @(isCompleted ? "readonly" : "")>@Model.Conclusion</textarea>
                        </div>

                        @if (!isCompleted)
                        {
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Luu thong tin
                            </button>
                        }
                    </form>
                </div>
            </div>

            <!-- Chi dinh dich vu -->
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-clipboard-check"></i> Chi dinh dich vu
                        @if (pendingOrders.Any())
                        {
                            <span class="badge bg-warning text-dark float-end">
                                @pendingOrders.Count chi dinh chua co KQ
                            </span>
                        }
                    </h5>
                </div>
                <div class="card-body">
                    @if (!isCompleted)
                    {
                        <form method="post" asp-action="AddOrder" class="mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="encounterId" value="@Model.EncounterId" />
                            <div class="row g-2">
                                <div class="col-md-8">
                                    <select name="serviceId" class="form-select" required>
                                        <option value="">-- Chon dich vu --</option>
                                        @foreach (var s in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Services)
                                        {
                                            <option value="@s.Value">@s.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <button type="submit" class="btn btn-primary w-100">
                                        <i class="bi bi-plus-circle"></i> Them chi dinh
                                    </button>
                                </div>
                            </div>
                        </form>
                    }

                    @if (orders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Dich vu</th>
                                        <th>Loai</th>
                                        <th>Trang thai</th>
                                        <th>Ket qua</th>
                                        <th>Thao tac</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in orders)
                                    {
                                        <tr class="@(o.Status == HisMvc.Entities.OrderStatus.Resulted ? "table-success" : "")">
                                            <td><strong>#@o.OrderId</strong></td>
                                            <td>@o.Service?.Name</td>
                                            <td>
                                                <span class="badge bg-secondary">@o.Service?.Type</span>
                                            </td>
                                            <td>
                                                @if (o.Status == HisMvc.Entities.OrderStatus.Requested)
                                                {
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="bi bi-hourglass-split"></i> Cho xu ly
                                                    </span>
                                                }
                                                else if (o.Status == HisMvc.Entities.OrderStatus.Resulted)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-check-circle"></i> Da co KQ
                                                    </span>
                                                }
                                                else if (o.Status == HisMvc.Entities.OrderStatus.Cancelled)
                                                {
                                                    <span class="badge bg-danger">Da huy</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@o.Status</span>
                                                }
                                            </td>
                                            <td>
                                                @if (o.OrderResult != null)
                                                {
                                                    <div class="alert alert-success mb-0 py-2">
                                                        <strong><i class="bi bi-check-circle"></i> Da co ket qua</strong><br />
                                                        <small class="text-muted">
                                                            @o.OrderResult.ResultedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                        </small><br />
                                                        <div class="mt-1 p-2 bg-light rounded">
                                                            <small><strong>Ket qua:</strong> @o.OrderResult.ResultText</small>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="alert alert-warning mb-0 py-2">
                                                        <i class="bi bi-hourglass-split"></i> Chua co ket qua
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                @if (!isCompleted && o.Status == HisMvc.Entities.OrderStatus.Requested)
                                                {
                                                    <form method="post" asp-action="CancelOrder" style="display: inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="orderId" value="@o.OrderId" />
                                                        <input type="hidden" name="encounterId" value="@Model.EncounterId" />
                                                        <button type="submit" class="btn btn-sm btn-danger"
                                                                onclick="return confirm('Huy chi dinh nay?')">
                                                            <i class="bi bi-x-circle"></i> Huy
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Chua co chi dinh dich vu nao
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar Thao tac -->
        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-tools"></i> Thao tac</h5>
                </div>
                <div class="card-body">
                    @if (!isCompleted)
                    {
                        <div class="mb-3">
                            <h6 class="text-muted">Trang thai hien tai:</h6>
                            @if (Model.Status == HisMvc.Entities.EncounterStatus.CheckedIn)
                            {
                                <span class="badge bg-info">Dang cho kham</span>
                            }
                            else if (Model.Status == HisMvc.Entities.EncounterStatus.InService)
                            {
                                <span class="badge bg-warning text-dark">Dang kham</span>
                            }
                        </div>

                        <div class="alert alert-warning">
                            <small>
                                <i class="bi bi-exclamation-triangle"></i> 
                                <strong>Dieu kien chot:</strong><br />
                                ✓ Phai co chan doan<br />
                                ✓ Tat ca chi dinh da co ket qua
                            </small>
                        </div>

                        @if (pendingOrders.Any())
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-circle"></i>
                                Con <strong>@pendingOrders.Count</strong> chi dinh chua co ket qua!
                            </div>
                        }

                        @if (string.IsNullOrEmpty(Model.Diagnosis))
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-circle"></i>
                                Chua co chan doan!
                            </div>
                        }

                        <form method="post" asp-action="Close">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.EncounterId" />
                            <button type="submit" class="btn btn-danger w-100 mb-3"
                                    onclick="return confirm('Ban co chac muon CHOT luot kham nay?\n\nSau khi chot se khong the sua duoc.\n\n✓ Da co chan doan?\n✓ Tat ca chi dinh da co ket qua?')">
                                <i class="bi bi-lock"></i> CHOT luot kham
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle"></i> 
                            <strong>Luot kham da hoan thanh</strong><br />
                            <small>Chot luc: @Model.EndAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</small>
                        </div>

                        <form method="post" asp-action="Reopen">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.EncounterId" />
                            <button type="submit" class="btn btn-warning w-100 mb-3"
                                    onclick="return confirm('Mo lai luot kham de chinh sua?')">
                                <i class="bi bi-unlock"></i> Mo lai luot kham
                            </button>
                        </form>
                    }

                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left"></i> Quay lai danh sach
                    </a>
                </div>
            </div>

            <!-- Thong tin them -->
            <div class="card shadow-sm mt-3">
                <div class="card-header bg-secondary text-white">
                    <h6 class="mb-0"><i class="bi bi-info-circle"></i> Huong dan</h6>
                </div>
                <div class="card-body">
                    <small>
                        <p class="mb-2"><strong>1. Nhap thong tin kham:</strong></p>
                        <ul class="mb-2">
                            <li>Chan doan (bat buoc)</li>
                            <li>Ket luan, dan do</li>
                        </ul>
                        
                        <p class="mb-2"><strong>2. Chi dinh dich vu:</strong></p>
                        <ul class="mb-2">
                            <li>Chon dich vu can lam</li>
                            <li>Lab se nhap ket qua</li>
                        </ul>
                        
                        <p class="mb-2"><strong>3. Chot luot kham:</strong></p>
                        <ul class="mb-0">
                            <li>Kiem tra du dieu kien</li>
                            <li>Click "Chot luot kham"</li>
                            <li>BN co the thanh toan</li>
                        </ul>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
