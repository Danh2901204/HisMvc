@model OrderListViewModel
@{
    ViewData["Title"] = "Danh sách chỉ định";
    var serviceType = Model.ServiceType ?? "";
    var date = Model.SelectedDate;
    var departmentId = Model.DepartmentId;
    var departments = Model.Departments;
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-flask"></i> Danh sách chỉ định chờ kết quả</h2>
        <a href="@Url.Action("History")" class="btn btn-info">
            <i class="bi bi-clock-history"></i> Xem lịch sử
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Loại dịch vụ:</label>
                    <select name="serviceType" class="form-select">
                        <option value="">Tất cả (LAB + IMAGING)</option>
                        <option value="LAB" selected="@(serviceType == "LAB")">Xét nghiệm (LAB)</option>
                        <option value="IMAGING" selected="@(serviceType == "IMAGING")">Chẩn đoán hình ảnh</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ngày chỉ định:</label>
                    <input type="date" name="date" class="form-control" 
                           value="@(date?.ToString("yyyy-MM-dd"))" />
                    <small class="text-muted">Để trống = tất cả</small>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Khoa:</label>
                    <select name="departmentId" class="form-select">
                        <option value="">Tất cả các khoa</option>
                        @foreach (var dept in departments)
                        {
                            <option value="@dept.DepartmentId" selected="@(departmentId == dept.DepartmentId)">
                                @dept.Name
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary d-block w-100">
                        <i class="bi bi-search"></i> Lọc
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">
                <i class="bi bi-list-check"></i> Chỉ định cần thực hiện (@Model.Orders.Count)
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Orders.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Order ID</th>
                                <th><i class="bi bi-person"></i> Bệnh nhân</th>
                                <th><i class="bi bi-clipboard-check"></i> Dịch vụ</th>
                                <th><i class="bi bi-person-badge"></i> BS chỉ định</th>
                                <th><i class="bi bi-hospital"></i> Khoa</th>
                                <th><i class="bi bi-clock-history"></i> Thời gian</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model.Orders)
                            {
                                <tr>
                                    <td><strong>#@o.OrderId</strong></td>
                                    <td>
                                        <strong>@o.Encounter?.Patient?.FullName</strong><br />
                                        <small class="text-muted">
                                            <i class="bi bi-telephone"></i> @o.Encounter?.Patient?.Phone
                                        </small>
                                    </td>
                                    <td>
                                        @if (o.Service?.Type == "LAB")
                                        {
                                            <span class="badge bg-info text-dark">
                                                <i class="bi bi-flask"></i> LAB
                                            </span>
                                        }
                                        else if (o.Service?.Type == "IMAGING")
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-camera"></i> IMAGING
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@o.Service?.Type</span>
                                        }
                                        <br />
                                        @o.Service?.Name
                                    </td>
                                    <td>@o.Encounter?.Doctor?.FullName</td>
                                    <td>@o.Encounter?.Doctor?.Department?.Name</td>
                                    <td>
                                        <small>@o.OrderedAt.ToLocalTime().ToString("dd/MM/yyyy")</small><br />
                                        <small class="text-muted">@o.OrderedAt.ToLocalTime().ToString("HH:mm:ss")</small>
                                    </td>
                                    <td class="text-center">
                                        <a href="@Url.Action("Result", new { id = o.OrderId })" 
                                           class="btn btn-sm btn-primary">
                                            <i class="bi bi-pencil-square"></i> Nhập KQ
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-check-circle" style="font-size: 3rem; color: #28a745;"></i>
                    <p class="text-muted mt-3">
                        @if (string.IsNullOrEmpty(serviceType) && !date.HasValue && !departmentId.HasValue)
                        {
                            <text>Không có chỉ định nào đang chờ xử lý</text>
                        }
                        else
                        {
                            <text>Không có chỉ định phù hợp với điều kiện lọc</text>
                        }
                    </p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <div class="card">
            <div class="card-body">
                <h6>Chú thích:</h6>
                <div class="d-flex gap-3 flex-wrap">
                    <div>
                        <span class="badge bg-info text-dark"><i class="bi bi-flask"></i> LAB</span> - Xét nghiệm
                    </div>
                    <div>
                        <span class="badge bg-warning text-dark"><i class="bi bi-camera"></i> IMAGING</span> - Chẩn đoán hình ảnh
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}
