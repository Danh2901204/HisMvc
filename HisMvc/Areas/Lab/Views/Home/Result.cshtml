@model LabResultViewModel
@{
    ViewData["Title"] = "Nhập kết quả";
    var order = Model.Order;
    var hasResult = order.OrderResult != null;
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-clipboard-data"></i> Nhập kết quả - Order #@order.OrderId
                        @if (hasResult)
                        {
                            <span class="badge bg-warning text-dark float-end">
                                <i class="bi bi-check-circle"></i> Đã có kết quả
                            </span>
                        }
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="mb-2">
                                <strong><i class="bi bi-person-fill text-primary"></i> Bệnh nhân:</strong><br />
                                <span class="ms-4 fs-5">@order.Encounter?.Patient?.FullName</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-telephone-fill text-success"></i> Điện thoại:</strong><br />
                                <span class="ms-4">@order.Encounter?.Patient?.Phone</span>
                            </p>
                            @if (order.Encounter?.Patient?.Dob != null)
                            {
                                <p class="mb-2">
                                    <strong><i class="bi bi-calendar"></i> Ngày sinh:</strong><br />
                                    <span class="ms-4">
                                        @order.Encounter.Patient.Dob.Value.ToString("dd/MM/yyyy")
                                        (@((DateTime.Today.Year - order.Encounter.Patient.Dob.Value.Year)) tuổi)
                                    </span>
                                </p>
                            }
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2">
                                <strong><i class="bi bi-clipboard-check-fill text-info"></i> Dịch vụ:</strong><br />
                                <span class="ms-4">
                                    @if (order.Service?.Type == "LAB")
                                    {
                                        <span class="badge bg-info text-dark"><i class="bi bi-flask"></i> LAB</span>
                                    }
                                    else if (order.Service?.Type == "IMAGING")
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-camera"></i> IMAGING</span>
                                    }
                                    @order.Service?.Name
                                </span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-person-badge"></i> BS chỉ định:</strong><br />
                                <span class="ms-4">@order.Encounter?.Doctor?.FullName</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-clock"></i> Thời gian chỉ định:</strong><br />
                                <span class="ms-4">@order.OrderedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            </p>
                            <p class="mb-2">
                                <strong><i class="bi bi-info-circle-fill text-warning"></i> Trạng thái:</strong><br />
                                <span class="ms-4">
                                    @if (order.Status == HisMvc.Entities.OrderStatus.Requested)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-hourglass-split"></i> Chờ xử lý
                                        </span>
                                    }
                                    else if (order.Status == HisMvc.Entities.OrderStatus.Resulted)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Đã có kết quả
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@order.Status</span>
                                    }
                                </span>
                            </p>
                        </div>
                    </div>

                    @if (hasResult)
                    {
                        <div class="alert alert-info">
                            <strong><i class="bi bi-clock-history"></i> Kết quả đã nhập:</strong><br />
                            <small>
                                Thời gian: @order.OrderResult!.ResultedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")<br />
                                Người nhập: <strong>@order.OrderResult.ResultedBy</strong>
                            </small>
                        </div>
                    }

                    <hr />

                    <form method="post" asp-action="SaveResult">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@order.OrderId" />
                        
                        <div class="mb-3">
                            <label class="form-label">
                                <strong><i class="bi bi-file-text"></i> Kết quả xét nghiệm</strong>
                                <span class="text-danger">*</span>
                            </label>
                            <textarea name="resultText" 
                                      rows="10" 
                                      class="form-control" 
                                      placeholder="Nhập kết quả xét nghiệm chi tiết..."
                                      required>@(order.OrderResult?.ResultText)</textarea>
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> 
                                Nhập đầy đủ thông tin kết quả xét nghiệm/chẩn đoán hình ảnh
                            </small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <div>
                                <a href="@Url.Action("Index")" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                                </a>
                                @if (hasResult)
                                {
                                    <button type="button" class="btn btn-danger" 
                                            onclick="if(confirm('Xóa kết quả này và chuyển về trạng thái chờ xử lý?')) { document.getElementById('clearForm').submit(); }">
                                        <i class="bi bi-trash"></i> Xóa kết quả
                                    </button>
                                }
                            </div>
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-save"></i> 
                                @if (hasResult)
                                {
                                    <text>Cập nhật kết quả</text>
                                }
                                else
                                {
                                    <text>Lưu kết quả</text>
                                }
                            </button>
                        </div>
                    </form>

                    @if (hasResult)
                    {
                        <form id="clearForm" method="post" asp-action="ClearResult" style="display:none;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="orderId" value="@order.OrderId" />
                        </form>
                    }
                </div>
            </div>

            @if (hasResult)
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-file-earmark-text"></i> Kết quả hiện tại</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-success mb-0">
                            <strong><i class="bi bi-check-circle"></i> Kết quả:</strong>
                            <pre class="mb-0 mt-2">@order.OrderResult!.ResultText</pre>
                            <hr />
                            <small class="text-muted">
                                <i class="bi bi-clock"></i> Nhập lúc: @order.OrderResult.ResultedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")<br />
                                <i class="bi bi-person"></i> Người nhập: <strong>@order.OrderResult.ResultedBy</strong>
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        pre {
            white-space: pre-wrap;
            word-wrap: break-word;
            background-color: #f8f9fa;
            padding: 15px;
            border-radius: 5px;
            border-left: 4px solid #28a745;
        }
    </style>
}
