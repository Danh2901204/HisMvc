@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-primary">
            <i class="bi bi-hospital"></i> HIS Management System
        </h1>
        <p class="lead text-muted">Hệ thống quản lý bệnh viện - Hospital Information System</p>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="row g-3 mt-4 justify-content-center">
            @if (User.IsInRole("ADMIN"))
            {
                <div class="col-auto" style="flex: 0 0 19%; min-width: 200px; max-width: 250px;">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-body text-center p-3 d-flex flex-column">
                            <div class="mb-2">
                                <i class="bi bi-gear-fill display-4 text-danger"></i>
                            </div>
                            <h5 class="card-title">ADMIN</h5>
                            <p class="card-text text-muted small" style="min-height: 40px;">
                                Quản trị hệ thống
                            </p>
                            <a href="/Admin/Home/Index" class="btn btn-danger btn-sm mt-auto">
                                <i class="bi bi-arrow-right-circle"></i> Truy cập
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (User.IsInRole("RECEPTION") || User.IsInRole("ADMIN"))
            {
                <div class="col-auto" style="flex: 0 0 19%; min-width: 200px; max-width: 250px;">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-body text-center p-3 d-flex flex-column">
                            <div class="mb-2">
                                <i class="bi bi-calendar-check display-4 text-primary"></i>
                            </div>
                            <h5 class="card-title">Lễ tân</h5>
                            <p class="card-text text-muted small" style="min-height: 40px;">
                                Lịch hẹn & check-in
                            </p>
                            <a href="/Reception/Home/Index" class="btn btn-primary btn-sm mt-auto">
                                <i class="bi bi-arrow-right-circle"></i> Truy cập
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (User.IsInRole("DOCTOR") || User.IsInRole("ADMIN"))
            {
                <div class="col-auto" style="flex: 0 0 19%; min-width: 200px; max-width: 250px;">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-body text-center p-3 d-flex flex-column">
                            <div class="mb-2">
                                <i class="bi bi-stethoscope display-4 text-success"></i>
                            </div>
                            <h5 class="card-title">Bác sĩ</h5>
                            <p class="card-text text-muted small" style="min-height: 40px;">
                                Khám bệnh
                            </p>
                            <a href="/Doctor/Home/Index" class="btn btn-success btn-sm mt-auto">
                                <i class="bi bi-arrow-right-circle"></i> Truy cập
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (User.IsInRole("LAB_TECH") || User.IsInRole("ADMIN"))
            {
                <div class="col-auto" style="flex: 0 0 19%; min-width: 200px; max-width: 250px;">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-body text-center p-3 d-flex flex-column">
                            <div class="mb-2">
                                <i class="bi bi-flask display-4 text-info"></i>
                            </div>
                            <h5 class="card-title">Xét nghiệm</h5>
                            <p class="card-text text-muted small" style="min-height: 40px;">
                                Kết quả xét nghiệm
                            </p>
                            <a href="/Lab/Home/Index" class="btn btn-info btn-sm mt-auto">
                                <i class="bi bi-arrow-right-circle"></i> Truy cập
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (User.IsInRole("CASHIER") || User.IsInRole("ADMIN"))
            {
                <div class="col-auto" style="flex: 0 0 19%; min-width: 200px; max-width: 250px;">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-body text-center p-3 d-flex flex-column">
                            <div class="mb-2">
                                <i class="bi bi-cash-coin display-4 text-warning"></i>
                            </div>
                            <h5 class="card-title">Viện phí</h5>
                            <p class="card-text text-muted small" style="min-height: 40px;">
                                Hóa đơn & thanh toán
                            </p>
                            <a href="/Cashier/Home/Index" class="btn btn-warning btn-sm mt-auto">
                                <i class="bi bi-arrow-right-circle"></i> Truy cập
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (User.IsInRole("PHARMACIST") || User.IsInRole("ADMIN"))
            {
                <div class="col-auto" style="flex: 0 0 19%; min-width: 200px; max-width: 250px;">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-body text-center p-3 d-flex flex-column">
                            <div class="mb-2">
                                <i class="bi bi-capsule display-4 text-secondary"></i>
                            </div>
                            <h5 class="card-title">Dược</h5>
                            <p class="card-text text-muted small" style="min-height: 40px;">
                                Kê đơn & cấp phát thuốc
                            </p>
                            <a href="/Pharmacy/Home/Index" class="btn btn-secondary btn-sm mt-auto">
                                <i class="bi bi-arrow-right-circle"></i> Truy cập
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (User.IsInRole("DOCTOR") || User.IsInRole("ADMIN"))
            {
                <div class="col-auto" style="flex: 0 0 19%; min-width: 200px; max-width: 250px;">
                    <div class="card h-100 shadow-sm hover-card">
                        <div class="card-body text-center p-3 d-flex flex-column">
                            <div class="mb-2">
                                <i class="bi bi-hospital-fill display-4 text-dark"></i>
                            </div>
                            <h5 class="card-title">Nội trú</h5>
                            <p class="card-text text-muted small" style="min-height: 40px;">
                                Quản lý bệnh nhân nằm viện
                            </p>
                            <a href="/Inpatient/Home/Index" class="btn btn-dark btn-sm mt-auto">
                                <i class="bi bi-arrow-right-circle"></i> Truy cập
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row mt-5">
            <div class="col-md-12">
                <div class="card shadow-sm">
                    <div class="card-body text-center p-4">
                        <h5 class="mb-3">Chào mừng, <strong class="text-primary">@User.Identity.Name</strong>!</h5>
                        <p class="text-muted mb-0">
                            Vui lòng chọn chức năng phía trên để bắt đầu làm việc
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row justify-content-center mt-5">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-body text-center p-5">
                        <i class="bi bi-lock display-1 text-warning mb-4"></i>
                        <h3 class="mb-3">Yêu cầu đăng nhập</h3>
                        <p class="text-muted mb-4">
                            Vui lòng đăng nhập để truy cập hệ thống quản lý bệnh viện
                        </p>
                        <a href="/Account/Login" class="btn btn-primary btn-lg">
                            <i class="bi bi-box-arrow-in-right"></i> Đăng nhập ngày
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row mt-5">
        <div class="col-md-12">
            <div class="card border-0 bg-light">
                <div class="card-body text-center p-4">
                    <h5 class="text-muted mb-3">Tính năng hệ thống</h5>
                    <div class="row">
                        <div class="col-md-3">
                            <i class="bi bi-people text-primary" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0"><strong>Quản lý bệnh nhân</strong></p>
                        </div>
                        <div class="col-md-3">
                            <i class="bi bi-calendar-event text-success" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0"><strong>Đặt lịch hẹn</strong></p>
                        </div>
                        <div class="col-md-3">
                            <i class="bi bi-stethoscope text-danger" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0"><strong>Khám và chẩn đoán</strong></p>
                        </div>
                        <div class="col-md-3">
                            <i class="bi bi-flask text-info" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0"><strong>Xét nghiệm</strong></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        .hover-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
        }
    </style>
}
