@using HisMvc.Models
@{
    var isAuth = User.Identity?.IsAuthenticated == true;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HIS Management</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HisMvc.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(isAuth ? "has-sidebar" : "no-sidebar")">
    @if (isAuth)
    {
        <partial name="_Sidebar" />
    }

    <div class="app-shell">
        <header class="topbar">
            <div class="d-flex align-items-center gap-2">
                @if (isAuth)
                {
                    <button type="button" class="btn btn-link text-white px-2" id="sidebarToggle" title="Đóng / Mở thanh bên">
                        <i class="bi bi-list fs-3"></i>
                    </button>
                }
                <a class="navbar-brand text-white fw-bold mb-0" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-hospital"></i> HIS Management
                </a>
            </div>

            <div class="topbar-right">
                @if (isAuth)
                {
                    <div class="topbar-clock me-3 d-none d-md-block">
                        <i class="bi bi-clock-history"></i>
                        <span id="liveClock">--:--:--</span>
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-link text-white dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i>
                            <span class="d-none d-md-inline">@User.Identity?.Name</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">@string.Join(", ", User.Claims.Where(c => c.Type.EndsWith("/role")).Select(c => c.Value))</h6></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form method="post" asp-area="" asp-controller="Account" asp-action="Logout">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                    </a>
                }
            </div>
        </header>

        <main role="main" class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            const sidebar = document.getElementById('appSidebar');
            const toggle = document.getElementById('sidebarToggle');
            const body = document.body;
            const STORAGE_KEY = 'his.sidebar.collapsed';

            function setCollapsed(collapsed) {
                if (!sidebar) return;
                sidebar.classList.toggle('collapsed', collapsed);
                body.classList.toggle('sidebar-collapsed', collapsed);
                try { localStorage.setItem(STORAGE_KEY, collapsed ? '1' : '0'); } catch (_) { }
            }

            if (sidebar) {
                const saved = (() => { try { return localStorage.getItem(STORAGE_KEY); } catch (_) { return null; } })();
                if (saved === '1') setCollapsed(true);
                toggle?.addEventListener('click', () => setCollapsed(!sidebar.classList.contains('collapsed')));
            }

            // Live clock in topbar
            const clock = document.getElementById('liveClock');
            if (clock) {
                const tick = () => {
                    const d = new Date();
                    clock.textContent = d.toLocaleTimeString('vi-VN');
                };
                tick();
                setInterval(tick, 1000);
            }

            // Auto-refresh dashboards every 30s
            if (document.body.dataset.autoRefresh === '1') {
                setTimeout(() => location.reload(), 30000);
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
