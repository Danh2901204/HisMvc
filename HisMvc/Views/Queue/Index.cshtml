@using HisMvc.Entities
@{
    Layout = null;
    ViewData["Title"] = "Hang Chờ Phong Kham";
    var calling = (List<Encounter>)ViewBag.Calling;
    var waiting = (List<Encounter>)ViewBag.Waiting;
    var departments = (List<Department>)ViewBag.Departments;
    var dept = ViewBag.DepartmentId as int?;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content="10" />
    <title>STT Phong Kham</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body { background: linear-gradient(135deg, #1e3a8a, #0f172a); color: #fff; min-height: 100vh; font-family: 'Segoe UI', sans-serif; }
        .calling-card { background: #ef4444; border-radius: 16px; padding: 28px; text-align: center; animation: blink 1.5s infinite; box-shadow: 0 8px 24px rgba(239,68,68,.4); }
        @@keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: .7; } }
        .calling-card .stt { font-size: 6rem; font-weight: 900; line-height: 1; }
        .calling-card .label { font-size: 1.2rem; opacity: .9; }
        .calling-card .info { font-size: 1.6rem; margin-top: 8px; }
        .wait-card { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 12px; padding: 14px; text-align: center; }
        .wait-card .num { font-size: 2.4rem; font-weight: 700; color: #fbbf24; }
        .wait-card .name { font-size: .9rem; opacity: .8; }
        .topbar { background: rgba(0,0,0,.35); padding: 18px 28px; }
        h1 { font-weight: 800; letter-spacing: 2px; }
        .clock { font-size: 1.5rem; }
    </style>
</head>
<body>
    <div class="topbar d-flex justify-content-between align-items-center">
        <h1 class="mb-0"><i class="bi bi-hospital"></i> HIS - HANG DOI PHONG KHAM</h1>
        <div>
            <form method="get" class="d-flex align-items-center gap-2">
                <select name="departmentId" class="form-select form-select-sm bg-transparent text-white border-light" onchange="this.form.submit()">
                    <option value="">Tất cả khoa</option>
                    @foreach (var d in departments)
                    {
                        <option value="@d.DepartmentId" selected="@(dept == d.DepartmentId)">@d.Name</option>
                    }
                </select>
                <span class="clock" id="clk">--:--:--</span>
            </form>
        </div>
    </div>

    <div class="container-fluid py-4">
        <h3 class="text-uppercase mb-3"><i class="bi bi-megaphone"></i> Đang Goi</h3>
        @if (!calling.Any())
        {
            <div class="alert alert-warning bg-transparent border-warning text-warning">Không có BN nao dang được gọi.</div>
        }
        else
        {
            <div class="row g-3 mb-5">
                @foreach (var c in calling)
                {
                    <div class="col-md-3">
                        <div class="calling-card">
                            <div class="label">STT</div>
                            <div class="stt">@c.QueueNumber</div>
                            <div class="info">@c.Patient?.FullName</div>
                            <div class="info">Phong @(c.RoomNumber ?? "-")</div>
                            <div class="small mt-2">BS @c.Doctor?.FullName</div>
                        </div>
                    </div>
                }
            </div>
        }

        <h3 class="text-uppercase mb-3"><i class="bi bi-people"></i> Đang Cho</h3>
        @if (!waiting.Any())
        {
            <div class="alert alert-info bg-transparent border-info text-info">Không có BN cho.</div>
        }
        else
        {
            <div class="row g-2">
                @foreach (var w in waiting)
                {
                    <div class="col-md-2 col-sm-3 col-4">
                        <div class="wait-card">
                            <div class="num">@w.QueueNumber</div>
                            <div class="name">@w.Patient?.FullName</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <script>
        const c = document.getElementById('clk');
        const tick = () => c.textContent = new Date().toLocaleTimeString('vi-VN');
        tick(); setInterval(tick, 1000);
    </script>
</body>
</html>
