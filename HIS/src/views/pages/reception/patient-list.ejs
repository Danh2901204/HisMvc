<div class="row">
    <div class="col">
        <div class="card">
            <div class="h1">Danh sách bệnh nhân</div>
            <div class="muted">Tra cứu nhanh hồ sơ bệnh nhân đã tiếp nhận.</div>
            <div style="height:12px"></div>

            <div class="actions">
                <a class="btn" href="/reception/patients/new">+ Tạo hồ sơ</a>
                <a class="btn secondary" href="/reception/visits/new">Đăng ký lượt khám</a>
                <a class="btn secondary" href="/dashboard">Quay lại Dashboard</a>
                <span class="badge">Tổng: <%= patients.length %></span>
            </div>

            <div style="height:14px"></div>

            <table class="table">
                <thead>
                    <tr>
                        <th>Mã BN</th>
                        <th>Họ tên</th>
                        <th>Ngày sinh</th>
                        <th>SĐT</th>
                        <th>CCCD</th>
                    </tr>
                </thead>
                <tbody>
                    <% patients.forEach(p => { %>
                        <tr>
                            <td><%= p.id %></td>
                            <td><%= p.name %></td>
                            <td><%= p.dob || "" %></td>
                            <td><%= p.phone || "" %></td>
                            <td><%= p.cccd || "" %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>