<div class="container" style="max-width: 400px; padding-top: 5rem;">
    <div class="card">
        <h1 class="h1 text-center">Login to HIS</h1>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger" style="margin-bottom: 1rem;"><%= error %></div>
        <% } %>

        <form action="/auth/login" method="POST" class="form">
            <div class="field">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" required>
            </div>
            <div class="field">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
            </div>
            <div class="field" style="margin-top: 1rem;">
                <button type="submit" class="btn" style="width: 100%;">Login</button>
            </div>
        </form>
    </div>
</div>