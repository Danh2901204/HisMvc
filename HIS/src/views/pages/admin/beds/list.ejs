<div class="row">
    <div class="col">
        <div class="card">
            <div class="h1">Quản lý giường</div>
            <div class="muted">Thêm, sửa, xóa và quản lý các giường trong hệ thống.</div>
            <div style="height:12px"></div>

            <div class="actions">
                <a class="btn" href="/admin/beds/new">+ Thêm giường</a>
                <a class="btn secondary" href="/dashboard">Quay lại Dashboard</a>
                <span class="badge">Tổng: <%= beds.length %></span>
            </div>

            <div style="height:14px"></div>

            <% if (beds.length > 0) { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Số giường</th>
                            <th>Phòng</th>
                            <th>Trạng thái</th>
                            <th style="width: 180px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% beds.forEach(bed => { %>
                            <tr>
                                <td><%= bed.bedNumber %></td>
                                <td><%= bed.room ? bed.room.roomNumber : 'N/A' %></td>
                                <td><%= bed.isOccupied ? 'Đã có người' : 'Trống' %></td>
                                <td>
                                    <div class="actions">
                                        <a href="/admin/beds/<%= bed._id %>/edit" class="btn secondary">Sửa</a>
                                        <form action="/admin/beds/<%= bed._id %>/delete" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa giường này không?');" style="display: inline;">
                                            <button type="submit" class="btn secondary">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <div style="padding: 2rem; text-align: center;">
                    <p class="muted">Chưa có giường nào được tạo.</p>
                    <a href="/admin/beds/new" class="btn">Tạo giường đầu tiên</a>
                </div>
            <% } %>
        </div>
    </div>
</div>