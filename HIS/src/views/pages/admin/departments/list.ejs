<div class="row">
    <div class="col">
        <div class="card">
            <div class="h1">Quản lý phòng ban</div>
            <div class="muted">Thêm, sửa, xóa và quản lý các phòng ban trong hệ thống.</div>
            <div style="height:12px"></div>

            <div class="actions">
                <a class="btn" href="/admin/departments/new">+ Thêm phòng ban</a>
                <a class="btn secondary" href="/dashboard">Quay lại Dashboard</a>
                <span class="badge">Tổng: <%= departments.length %></span>
            </div>

            <div style="height:14px"></div>

            <% if (departments.length > 0) { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Tên phòng ban</th>
                            <th>Mô tả</th>
                            <th style="width: 180px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% departments.forEach(department => { %>
                            <tr>
                                <td><%= department.deptName %></td>
                                <td><%= department.description %></td>
                                <td>
                                    <div class="actions">
                                        <a href="/admin/departments/<%= department._id %>/edit" class="btn secondary">Sửa</a>
                                        <form action="/admin/departments/<%= department._id %>/delete" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phòng ban này không?');" style="display: inline;">
                                            <button type="submit" class="btn secondary">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <div style="padding: 2rem; text-align: center;">
                    <p class="muted">Chưa có phòng ban nào được tạo.</p>
                    <a href="/admin/departments/new" class="btn">Tạo phòng ban đầu tiên</a>
                </div>
            <% } %>
        </div>
    </div>
</div>