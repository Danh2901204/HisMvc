<div class="container">
    <h1 class="h1">User Management</h1>

    <div class="row">
        <div class="col" style="flex: 0 1 380px;">
            <div class="card">
                <h2 class="h1">Create New User</h2>
                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                <% if (success) { %>
                    <div class="alert alert-success"><%= success %></div>
                <% } %>
                <form action="/admin/users" method="POST" class="form">
                    <div class="field">
                        <label for="username">Username</label>
                        <input type="text" name="username" required>
                    </div>
                    <div class="field">
                        <label for="password">Password</label>
                        <input type="password" name="password" required>
                    </div>
                    <div class="field">
                        <label for="firstName">First Name</label>
                        <input type="text" name="firstName" required>
                    </div>
                    <div class="field">
                        <label for="lastName">Last Name</label>
                        <input type="text" name="lastName" required>
                    </div>
                    <div class="field">
                        <label for="email">Email</label>
                        <input type="email" name="email" required>
                    </div>
                    <div class="field">
                        <label for="specialty">Specialty</label>
                        <select name="specialty">
                            <% departments.forEach(department => { %>
                                <option value="<%= department.deptName %>"><%= department.deptName %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="field">
                        <label for="role">Role</label>
                        <select name="role">
                            <% roles.forEach(role => { %>
                                <option value="<%= role %>"><%= role %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="field">
                        <button type="submit" class="btn">Create User</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="col">
            <div class="card">
                <h2 class="h1">Existing Users</h2>
                <% if (users.length > 0) { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Full Name</th>
                            <th>Staff Code</th>
                            <th>Role</th>
                            <th style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(user => { %>
                            <tr>
                                <td><%= user.username %></td>
                                <td><%= user.staff ? user.staff.fullName : 'N/A' %></td>
                                <td><%= user.staff ? user.staff.staffCode : 'N/A' %></td>
                                <td><%= user.role %></td>
                                <td>
                                    <div class="actions">
                                        <a href="/admin/users/edit/<%= user._id %>" class="btn secondary">Edit</a>
                                        <form action="/admin/users/delete/<%= user._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this user?');" style="display: inline;">
                                            <button type="submit" class="btn secondary" style="color:#dc2626; background:#fef2f2;">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
                <% } else { %>
                    <div style="padding: 2rem; text-align: center;">
                        <p class="muted">No users have been created yet.</p>
                        <a href="/admin/users" class="btn">Create the first user</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>