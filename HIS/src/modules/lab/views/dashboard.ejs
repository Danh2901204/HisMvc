<%- include('../../views/partials/header') %>

<div class="container mt-4">
    <h2>Lab Dashboard</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Patient</th>
                <th>Test</th>
                <th>Status</th>
                <th>Date Ordered</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% labOrders.forEach(order => { %>
                <tr>
                    <td><%= order.patientId.name %></td>
                    <td><%= order.labTestId.name %></td>
                    <td><%= order.status %></td>
                    <td><%= new Date(order.date).toLocaleDateString() %></td>
                    <td>
                        <a href="/lab/<%= order._id %>" class="btn btn-primary">View</a>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<%- include('../../views/partials/footer') %>